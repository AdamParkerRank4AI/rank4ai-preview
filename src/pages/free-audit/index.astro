---
import Breadcrumbs from '../../components/Breadcrumbs.astro'
import Layout from '../../layouts/Layout.astro'
import AuditForm from '../../components/AuditForm.astro'
import FAQ from '../../components/FAQ.astro'
---
<Layout title="Free AI Search Audit UK 2026: Visibility Across 6 AI Platforms" description="Free UK AI Search Audit. We test how your business appears across ChatGPT, Claude, Gemini, Perplexity, Copilot and Google AI Overviews. Five Signal Model report, no obligation.">

<section class="pt-12 pb-24">
  <div class="container-narrow">
    <div class="text-center mb-12">
      <p class="text-[13px] font-semibold uppercase tracking-[0.1em] text-accent mb-4">Free Audit</p>
      <h1 class="mb-4">Get a Free AI Search Visibility Audit</h1>
      <p class="text-[17px] text-text-muted leading-relaxed max-w-[480px] mx-auto mb-2">We test your business across ChatGPT, Claude, Gemini, Perplexity, Copilot and Google AI. You get a detailed report showing exactly where you stand.</p>
      <p class="text-sm text-text-muted">1,400+ UK businesses audited. Delivered within 5 working days.</p>
    </div>

    <AuditForm />
  </div>


    <section class="mt-16 pt-12 border-t border-gray-200">
      <h2 class="mb-6">Frequently asked questions</h2>
      <FAQ items={[{"question": "What does the free AI search audit cover?", "answer": "We test your brand visibility across ChatGPT, Claude, Gemini, Perplexity and Google AI Overviews. You get: your score for each platform, 5 sample queries showing where you do and don't appear, 3 priority fixes ranked by impact, and an entity clarity assessment. Delivered as a written report within 48 hours."}, {"question": "Is it really free?", "answer": "Yes. The audit is free and has no obligation. We offer it because 76% of businesses we audit discover gaps they didn't know existed, and many go on to engage us. For those who don't, the audit itself has value."}, {"question": "How is the free audit different from your paid audit?", "answer": "The free audit covers brand queries (5 per platform) and returns a single summary. The paid audit (\u00a31,500) covers 50+ queries including commercial intent, runs across 6 platforms, benchmarks 3 named competitors, and delivers a 30 to 50 page report with a full 90-day action plan."}]} />
    </section>
  </section>

</Layout>
