---
import Layout from '../../layouts/Layout.astro'
---
<Layout title="Free AI Search Visibility Audit | Rank4AI" description="Get a free AI Search Visibility Audit from Rank4AI. We test how your business appears across ChatGPT, Claude, Gemini, Perplexity, Copilot and Google AI.">

<section class="pt-24 pb-24">
  <div class="max-w-[600px] mx-auto px-10 max-md:px-6 text-center">
    <p class="text-[13px] font-semibold uppercase tracking-[0.1em] text-accent mb-4">UK AI Search Agency</p>
    <h1 class="mb-6">Get a Free AI Search Visibility Audit</h1>
    <p class="text-[17px] text-text-muted leading-relaxed mb-4">We test your business across ChatGPT, Claude, Gemini, Perplexity, Copilot and Google AI. You get a detailed report showing exactly where you stand.</p>
    <p class="text-sm text-text-muted mb-10">1,400+ UK businesses audited. No obligation.</p>

    <form action="https://formsubmit.co/info@rank4ai.co.uk" method="POST" class="text-left space-y-4 mb-8">
          <input type="hidden" name="_subject" value="New AI Search Visibility Audit request">
          <input type="hidden" name="_next" value="https://www.rank4ai.co.uk/free-audit/?submitted=true">
          <input type="hidden" name="_captcha" value="false">
          <input type="text" name="_honey" style="display:none">
      <div>
        <label class="block text-sm font-medium text-teal mb-1">Name *</label>
        <input type="text" required class="w-full px-4 py-3 border border-border rounded-lg bg-white-pure text-sm" placeholder="Your name">
      </div>
      <div>
        <label class="block text-sm font-medium text-teal mb-1">Email *</label>
        <input type="email" required class="w-full px-4 py-3 border border-border rounded-lg bg-white-pure text-sm" placeholder="your@email.com">
      </div>
      <div>
        <label class="block text-sm font-medium text-teal mb-1">Website URL *</label>
        <input type="url" required class="w-full px-4 py-3 border border-border rounded-lg bg-white-pure text-sm" placeholder="https://yourwebsite.com">
      </div>
      <div>
        <label class="block text-sm font-medium text-teal mb-1">What does your business do?</label>
        <textarea rows="3" class="w-full px-4 py-3 border border-border rounded-lg bg-white-pure text-sm" placeholder="Brief description of your business and services"></textarea>
      </div>
      <button type="submit" class="cta-primary w-full justify-center">Get My Free Audit &rarr;</button>
    </form>

    <p class="text-xs text-text-muted">Data-driven insights. No spam. No commitment required.</p>
  </div>
</section>

</Layout>
