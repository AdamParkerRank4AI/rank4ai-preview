---
import Breadcrumbs from '../../components/Breadcrumbs.astro'
import Layout from '../../layouts/Layout.astro'
---
<Layout title="Contact Rank4AI | AI Search Visibility" description="Contact Rank4AI. Get in touch or book a call. 40 De Vere Road, Colchester, CO3 4EA.">

<section class="pt-12 pb-24 reveal">
  <div class="container-narrow">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Contact' }
    ]} />

    <p class="section-tag">Contact</p>
    <h1 class="mb-6">Contact Rank4AI</h1>

    <img src="/images/content/ai-search-signals.svg" alt="AI search visibility signals" class="w-full rounded-xl mb-8 mt-6" loading="lazy">
    <p class="text-[17px] text-text-muted leading-relaxed mb-10">If you want to improve how AI systems interpret and recommend your business, use the form below or book a call.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <div>
        <h2 class="!text-xl mb-4">Send a Message</h2>
        <form action="https://formsubmit.co/info@rank4ai.co.uk" method="POST" class="space-y-4">
          <input type="hidden" name="_subject" value="New contact from Rank4AI website">
          <input type="hidden" name="_next" value="https://www.rank4ai.co.uk/contact/?submitted=true">
          <input type="hidden" name="_captcha" value="false">
          <input type="text" name="_honey" style="display:none">
          <div>
            <label class="block text-sm font-medium text-teal mb-1">Name</label>
            <input type="text" class="w-full px-4 py-3 border border-border rounded-lg bg-white-pure text-sm" placeholder="Your name">
          </div>
          <div>
            <label class="block text-sm font-medium text-teal mb-1">Email</label>
            <input type="email" class="w-full px-4 py-3 border border-border rounded-lg bg-white-pure text-sm" placeholder="your@email.com">
          </div>
          <div>
            <label class="block text-sm font-medium text-teal mb-1">Phone</label>
            <input type="tel" class="w-full px-4 py-3 border border-border rounded-lg bg-white-pure text-sm" placeholder="Optional">
          </div>
          <div>
            <label class="block text-sm font-medium text-teal mb-1">Website URL</label>
            <input type="url" class="w-full px-4 py-3 border border-border rounded-lg bg-white-pure text-sm" placeholder="https://yourwebsite.com">
          </div>
          <div>
            <label class="block text-sm font-medium text-teal mb-1">Message</label>
            <textarea rows="4" class="w-full px-4 py-3 border border-border rounded-lg bg-white-pure text-sm" placeholder="What do you want to improve?"></textarea>
          </div>
          <button type="submit" class="cta-primary w-full justify-center">Send Message</button>
        </form>
      </div>
      <div>
        <h2 class="!text-xl mb-4">Other Ways to Reach Us</h2>
        <div class="space-y-6">
          <div class="card">
            <h3 class="!text-base text-teal mb-2">Book a Call</h3>
            <p class="text-sm text-text-muted mb-3">30-minute discovery call to discuss your situation.</p>
            <a href="https://calendly.com/rank4ai/rank4aidiscovery" target="_blank" rel="noopener" class="link text-sm">Book on Calendly &rarr;</a>
          </div>
          <div class="card">
            <h3 class="!text-base text-teal mb-2">Free AI Search Visibility Audit</h3>
            <p class="text-sm text-text-muted mb-3">Get a detailed report showing how AI currently interprets your business.</p>
            <a href="/free-audit/" class="link text-sm">Start your free audit &rarr;</a>
          </div>
          <div class="card">
            <h3 class="!text-base text-teal mb-2">WhatsApp</h3>
            <p class="text-sm text-text-muted mb-3">Quick question? Chat to us directly.</p>
            <a href="https://wa.me/447389183338" target="_blank" rel="noopener" class="link text-sm">Chat on WhatsApp &rarr;</a>
          </div>
          <div class="card">
            <h3 class="!text-base text-teal mb-2">Address</h3>
            <p class="text-sm text-text-muted">Rank4AI Ltd<br>40 De Vere Road<br>Colchester, Essex<br>CO3 4EA</p>
            <p class="text-sm text-text-muted mt-2">info@rank4ai.co.uk</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

</Layout>
