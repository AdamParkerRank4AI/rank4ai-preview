---
// Standalone landing page - no standard header/footer
import '../../styles/global.css'
import AuditForm from '../../components/AuditForm.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Get Your Business on ChatGPT | Rank4AI</title>
  <meta name="description" content="Get your business recommended by ChatGPT. Free AI Search Visibility Audit from Rank4AI.">
  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" href={`${base}/logo.png`}>
</head>
<body class="bg-white min-h-screen">
  <div class="max-w-[640px] mx-auto px-6 py-12">
    <img src={`${base}/logo.svg`} alt="Rank4AI" class="h-8 mx-auto mb-10">

    <div class="text-center mb-10">
      <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-4">UK AI Search Agency</p>
      <h1 class="font-display text-3xl md:text-4xl text-teal leading-tight mb-4">Get Your Business Recommended by ChatGPT</h1>
      <p class="text-text-muted leading-relaxed">When someone asks ChatGPT to recommend a business like yours, do you appear? We test your visibility across all six AI platforms and show you exactly where you stand.</p>
    </div>

    <AuditForm />

    <p class="text-center text-xs text-text-muted mt-8">Rank4AI Ltd - Company 16584507 - <a href="/" class="underline">rank4ai.co.uk</a></p>
  </div>
</body>
</html>
