---
import '../../styles/global.css'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI-Ready Websites | Rank4AI</title>
  <meta name="description" content="Beautiful websites that rank on Google and get cited by ChatGPT.">
  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Serif+Display&display=swap" media="print" onload="this.media='all'">
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-WRG6QRCP');</script>
</head>
<body class="min-h-screen" style="background: #0a2421;">

  <!-- HERO: Tight, punchy -->
  <div class="py-12 px-6 text-center" style="background: #0a2421;">
    <div class="max-w-[560px] mx-auto">
      <img src={`${base}/logo-dark.svg`} alt="Rank4AI" class="h-5 mx-auto mb-8 opacity-50" role="img">
      <h1 class="font-display text-3xl md:text-[2.5rem] leading-tight mb-4" style="color: #f5f2eb;">Gorgeous on the surface.<br>Solid underneath.<br><span style="color: #2bb891;">Cited by AI.</span></h1>
      <p class="text-sm mb-8" style="color: #95a8a5;">Ranked on Google. Quoted by ChatGPT. Shown in AI Overviews.</p>
      <a href="#enquiry" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-lg font-semibold text-sm transition-all" style="background: linear-gradient(135deg, #3de8b6, #2bb891); color: #0a2421;" onclick="dataLayer.push({'event':'lp_hero_cta'})">Talk to us about your website &rarr;</a>
    </div>
  </div>

  <!-- SCORECARD: The comparison -->
  <div class="py-14 px-6" style="background: #f8f6f1;">
    <div class="max-w-[600px] mx-auto">
      <h2 class="font-display text-xl text-center mb-8" style="color: #0a2421;">Three ways to build a website</h2>

      <!-- Scorecard table -->
      <div class="rounded-2xl overflow-hidden border shadow-lg mb-8" style="border-color: #ddd8ce;">
        <!-- Header -->
        <div class="grid grid-cols-4 text-center text-xs font-semibold py-3" style="background: #0a2421; color: #95a8a5;">
          <div></div>
          <div>WordPress</div>
          <div>Lovable / Bolt</div>
          <div style="color: #2bb891;">Rank4AI</div>
        </div>

        <!-- Technical -->
        <div class="grid grid-cols-4 items-center text-center py-3 px-3 border-b" style="background: #fff; border-color: #eee;">
          <div class="text-xs font-semibold text-left" style="color: #0a2421;">Technical</div>
          <div class="font-display text-2xl" style="color: #e8a838;">7</div>
          <div class="font-display text-2xl" style="color: #d94f4f;">4</div>
          <div class="font-display text-2xl" style="color: #2bb891;">10</div>
        </div>

        <!-- Design -->
        <div class="grid grid-cols-4 items-center text-center py-3 px-3 border-b" style="background: #fff; border-color: #eee;">
          <div class="text-xs font-semibold text-left" style="color: #0a2421;">Design</div>
          <div class="font-display text-2xl" style="color: #d94f4f;">4</div>
          <div class="font-display text-2xl" style="color: #2bb891;">9</div>
          <div class="font-display text-2xl" style="color: #2bb891;">10</div>
        </div>

        <!-- Easy to manage -->
        <div class="grid grid-cols-4 items-center text-center py-3 px-3 border-b" style="background: #fff; border-color: #eee;">
          <div class="text-xs font-semibold text-left" style="color: #0a2421;">Easy to manage</div>
          <div class="font-display text-2xl" style="color: #d94f4f;">3</div>
          <div class="font-display text-2xl" style="color: #e8a838;">6</div>
          <div class="font-display text-2xl" style="color: #2bb891;">10</div>
        </div>

        <!-- AI can read it -->
        <div class="grid grid-cols-4 items-center text-center py-3 px-3 border-b" style="background: #fff; border-color: #eee;">
          <div class="text-xs font-semibold text-left" style="color: #0a2421;">AI can read it</div>
          <div class="font-display text-2xl" style="color: #d94f4f;">3</div>
          <div class="font-display text-2xl" style="color: #d94f4f;">2</div>
          <div class="font-display text-2xl" style="color: #2bb891;">10</div>
        </div>

        <!-- SEO ready -->
        <div class="grid grid-cols-4 items-center text-center py-3 px-3 border-b" style="background: #fff; border-color: #eee;">
          <div class="text-xs font-semibold text-left" style="color: #0a2421;">SEO ready</div>
          <div class="font-display text-2xl" style="color: #e8a838;">7</div>
          <div class="font-display text-2xl" style="color: #d94f4f;">3</div>
          <div class="font-display text-2xl" style="color: #2bb891;">10</div>
        </div>

        <!-- Speed -->
        <div class="grid grid-cols-4 items-center text-center py-3 px-3" style="background: #fff;">
          <div class="text-xs font-semibold text-left" style="color: #0a2421;">Speed</div>
          <div class="font-display text-2xl" style="color: #d94f4f;">4</div>
          <div class="font-display text-2xl" style="color: #e8a838;">7</div>
          <div class="font-display text-2xl" style="color: #2bb891;">10</div>
        </div>

        <!-- Total -->
        <div class="grid grid-cols-4 items-center text-center py-3 px-3" style="background: #0a2421;">
          <div class="text-xs font-bold text-left" style="color: #f5f2eb;">Total</div>
          <div class="font-display text-xl" style="color: #e8a838;">28/60</div>
          <div class="font-display text-xl" style="color: #d94f4f;">31/60</div>
          <div class="font-display text-xl" style="color: #2bb891;">60/60</div>
        </div>
      </div>

      <p class="text-xs text-center" style="color: #6b8280;">WordPress is solid but hard to manage. Lovable looks great but AI cannot read it. We do both, properly.</p>
    </div>
  </div>

  <!-- REVIEWS -->
  <div class="py-14 px-6" style="background: #fff;">
    <div class="max-w-[600px] mx-auto">
      <div class="space-y-3">
        <div class="rounded-xl p-5" style="background: #f5f3ee;">
          <p class="text-sm italic leading-relaxed mb-2" style="color: #3a524f;">"Last time I built a site I needed a web developer, then a content writer, then a designer. This time Rank4AI did it all for me, for the cost of just the site."</p>
          <p class="text-xs font-semibold" style="color: #0a2421;">Brian</p>
        </div>
        <div class="rounded-xl p-5" style="background: #f5f3ee;">
          <p class="text-sm italic leading-relaxed mb-2" style="color: #3a524f;">"I actually learnt so much. I thought my site was really good but they explained and showed me the issues. They were just passionate about getting it right and me understanding it."</p>
          <p class="text-xs font-semibold" style="color: #0a2421;">Amanda</p>
        </div>
        <div class="rounded-xl p-5" style="background: #f5f3ee;">
          <p class="text-sm italic leading-relaxed mb-2" style="color: #3a524f;">"I loved how simple Adam and Oliver made it. 'Write for humans and AI search will understand it' will stick with me. Now my site is simple and easy to understand, but it looks great."</p>
          <p class="text-xs font-semibold" style="color: #0a2421;">Steve</p>
        </div>
        <div class="rounded-xl p-5" style="background: #f5f3ee;">
          <p class="text-sm italic leading-relaxed mb-2" style="color: #3a524f;">"They clearly know their stuff, but they also take the time to explain what is being done and why. We were not passed down to juniors."</p>
          <p class="text-xs font-semibold" style="color: #0a2421;">Rishi, RB Financial</p>
        </div>
      </div>
    </div>
  </div>

  <!-- STATS BAR -->
  <div class="py-8 px-6" style="background: #0a2421;">
    <div class="max-w-[500px] mx-auto grid grid-cols-3 gap-4 text-center">
      <div>
        <div class="font-display text-2xl" style="color: #2bb891;">3.2x</div>
        <div class="text-[10px]" style="color: #95a8a5;">more traffic</div>
      </div>
      <div>
        <div class="font-display text-2xl" style="color: #2bb891;">2.7x</div>
        <div class="text-[10px]" style="color: #95a8a5;">more leads</div>
      </div>
      <div>
        <div class="font-display text-2xl" style="color: #2bb891;">2.5x</div>
        <div class="text-[10px]" style="color: #95a8a5;">more calls</div>
      </div>
    </div>
    <p class="text-center mt-3" style="color: #6b8280; font-size: 9px;">Sites crawled by AI. Source: Duda 2026, 858,000 websites.</p>
  </div>

  <!-- QUICK CHECK -->
  <div class="py-10 px-6" style="background: #f5f3ee;">
    <div class="max-w-[420px] mx-auto text-center">
      <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: #2bb891;">Quick check</p>
      <p class="text-sm mb-5" style="color: #3a524f;">Is your current site AI-ready? Enter your URL.</p>
      <form id="quick-check-form" class="flex gap-2">
        <input type="text" name="website" placeholder="yourwebsite.com" required class="flex-1 px-4 py-3 rounded-lg text-sm border focus:outline-none" style="border-color: #b5c8c3; background: #fff;">
        <button type="submit" class="px-5 py-3 rounded-lg text-sm font-semibold" style="background: #0a2421; color: #f5f2eb;">Check</button>
      </form>
      <p id="check-confirm" class="hidden text-sm mt-4" style="color: #2bb891;">Thanks. We will email you within 24 hours.</p>
    </div>
  </div>

  <!-- FORM -->
  <div class="py-14 px-6" style="background: #fff;" id="enquiry">
    <div class="max-w-[420px] mx-auto">
      <h2 class="font-display text-2xl text-center mb-2" style="color: #0a2421;">Talk to us about your website</h2>
      <p class="text-xs text-center mb-8" style="color: #6b8280;">No pitch. We will tell you honestly whether a rebuild is right.</p>

      <form id="enquiry-form" class="space-y-3">
        <input type="text" name="contact_name" required placeholder="Your name" class="w-full px-4 py-3 border rounded-lg text-sm focus:outline-none" style="border-color: #b5c8c3;">
        <input type="text" name="business_name" required placeholder="Business name" class="w-full px-4 py-3 border rounded-lg text-sm focus:outline-none" style="border-color: #b5c8c3;">
        <input type="text" name="website_url" placeholder="Current website (if any)" class="w-full px-4 py-3 border rounded-lg text-sm focus:outline-none" style="border-color: #b5c8c3;">
        <div class="grid grid-cols-2 gap-3">
          <input type="email" name="email" required placeholder="Email" class="w-full px-4 py-3 border rounded-lg text-sm focus:outline-none" style="border-color: #b5c8c3;">
          <input type="tel" name="phone" required placeholder="Phone" class="w-full px-4 py-3 border rounded-lg text-sm focus:outline-none" style="border-color: #b5c8c3;">
        </div>
        <div class="flex flex-wrap gap-2 py-1">
          <label class="cursor-pointer"><input type="radio" name="enquiry_type" value="New website" class="sr-only peer"><span class="inline-block px-4 py-2 border rounded-full text-xs font-medium peer-checked:text-white transition-all" style="border-color: #b5c8c3; color: #3a524f;" onchange="this.parentElement.querySelector('span').style.background='#0a2421'">New website</span></label>
          <label class="cursor-pointer"><input type="radio" name="enquiry_type" value="Rebuild" class="sr-only peer"><span class="inline-block px-4 py-2 border rounded-full text-xs font-medium peer-checked:text-white transition-all" style="border-color: #b5c8c3; color: #3a524f;">Rebuild</span></label>
          <label class="cursor-pointer"><input type="radio" name="enquiry_type" value="Not sure" class="sr-only peer"><span class="inline-block px-4 py-2 border rounded-full text-xs font-medium peer-checked:text-white transition-all" style="border-color: #b5c8c3; color: #3a524f;">Not sure</span></label>
        </div>
        <label class="flex items-start gap-2 cursor-pointer">
          <input type="checkbox" name="consent" required class="rounded mt-0.5" style="border-color: #b5c8c3;">
          <span style="font-size: 10px; color: #6b8280;">I agree to hear from Rank4AI. <a href="/privacy/" class="underline">Privacy</a>.</span>
        </label>
        <button type="submit" class="w-full py-3.5 rounded-lg font-semibold text-sm" style="background: #0a2421; color: #f5f2eb;">Get in touch &rarr;</button>
      </form>

      <div id="thank-you" class="hidden text-center py-8">
        <div class="text-3xl mb-3" style="color: #2bb891;">&#10003;</div>
        <p class="font-display text-lg mb-2" style="color: #0a2421;">Thanks</p>
        <p class="text-xs" style="color: #6b8280;">We will be in touch within 1 working day. <a href="https://wa.me/447389183338" style="color: #2bb891;">WhatsApp us</a> to talk sooner.</p>
      </div>
    </div>
  </div>

  <div class="text-center py-6" style="background: #0a2421;">
    <p style="font-size: 10px; color: #6b8280;">Rank4AI Ltd - 16584507 - <a href="/" class="underline" style="color: #6b8280;">rank4ai.co.uk</a></p>
  </div>

  <script>
    const params = new URLSearchParams(window.location.search);
    const source = params.get('utm_source') || 'direct';
    const medium = params.get('utm_medium') || 'organic';
    const campaign = params.get('utm_campaign') || '';
    const fullSource = `lp_ai_ready_sites|${source}|${medium}|${campaign}`;
    const SB_URL = 'https://tsscscjcxbzhicuuhter.supabase.co/rest/v1/conversations';
    const SB_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRzc2NzY2pjeGJ6aGljdXVodGVyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYwMzU1NDEsImV4cCI6MjA5MTYxMTU0MX0.Q4z8-zHq0RAjZ1Vnv339JwAY36aq5TvnDBwE7OvUNOM';
    const SB_H = { 'apikey': SB_KEY, 'Authorization': `Bearer ${SB_KEY}`, 'Content-Type': 'application/json' };

    document.getElementById('enquiry-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const fd = new FormData(form);
      const enquiryType = fd.get('enquiry_type') || 'Not specified';
      try {
        await fetch(SB_URL, { method: 'POST', headers: SB_H, body: JSON.stringify({
          company_name: fd.get('business_name'), contact_name: fd.get('contact_name'),
          email: fd.get('email'), phone: fd.get('phone'), website_url: fd.get('website_url') || null,
          source: fullSource, current_stage: 'new', audit_status: 'pending',
          notes: `Website enquiry. Type: ${enquiryType}`, goals: enquiryType, consent: true,
        })});
        const ed = new FormData();
        ed.append('_subject', `WEBSITE ENQUIRY: ${fd.get('business_name')}`);
        ed.append('Name', fd.get('contact_name') as string);
        ed.append('Business', fd.get('business_name') as string);
        ed.append('Website', fd.get('website_url') as string || 'None');
        ed.append('Email', fd.get('email') as string);
        ed.append('Phone', fd.get('phone') as string);
        ed.append('Type', enquiryType as string);
        ed.append('_captcha', 'false'); ed.append('_template', 'table');
        ed.append('_cc', 'adam@muswellrose.com,jimmy@rank4ai.online');
        fetch('https://formsubmit.co/ajax/info@rank4ai.online', { method: 'POST', body: ed });
        (window as any).dataLayer?.push({ 'event': 'lp_website_enquiry_conversion', 'enquiry_type': enquiryType });
      } catch (err) { console.error(err); }
      form.classList.add('hidden');
      document.getElementById('thank-you')?.classList.remove('hidden');
    });

    document.getElementById('quick-check-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const website = (form.querySelector('input[name="website"]') as HTMLInputElement).value;
      try {
        await fetch(SB_URL, { method: 'POST', headers: SB_H, body: JSON.stringify({
          company_name: website, contact_name: 'Quick Check', website_url: website,
          source: 'lp_ai_ready_sites_quick_check', current_stage: 'new', audit_status: 'pending',
          notes: 'Quick site check from LP.', consent: true,
        })});
        const ed = new FormData();
        ed.append('_subject', `QUICK CHECK: ${website}`);
        ed.append('Website', website); ed.append('_captcha', 'false');
        ed.append('_cc', 'adam@muswellrose.com,jimmy@rank4ai.online');
        fetch('https://formsubmit.co/ajax/info@rank4ai.online', { method: 'POST', body: ed });
        (window as any).dataLayer?.push({ 'event': 'lp_quick_check_conversion' });
      } catch (err) { console.error(err); }
      form.classList.add('hidden');
      document.getElementById('check-confirm')?.classList.remove('hidden');
    });

    // Radio pill styling
    document.querySelectorAll('#enquiry-form input[type="radio"]').forEach(r => {
      r.addEventListener('change', () => {
        document.querySelectorAll('#enquiry-form input[type="radio"]').forEach(rb => {
          const span = rb.parentElement?.querySelector('span');
          if (span) { span.style.background = ''; span.style.color = '#3a524f'; span.style.borderColor = '#b5c8c3'; }
        });
        const span = r.parentElement?.querySelector('span');
        if (span) { span.style.background = '#0a2421'; span.style.color = '#fff'; span.style.borderColor = '#0a2421'; }
      });
    });

    // Drop-off
    let started = false;
    document.querySelectorAll('#enquiry-form input').forEach(i => {
      i.addEventListener('focus', () => { if (!started) { started = true; (window as any).dataLayer?.push({'event':'lp_form_started'}); }});
    });
    window.addEventListener('beforeunload', () => {
      if (started && document.getElementById('thank-you')?.classList.contains('hidden')) {
        fetch(SB_URL, { method: 'POST', keepalive: true, headers: SB_H, body: JSON.stringify({
          company_name: 'DROP-OFF', source: fullSource, current_stage: 'new', notes: 'Form started, not submitted.', consent: true,
        })});
      }
    });
  </script>

</body>
</html>
