---
import '../../styles/global.css'
import AuditForm from '../../components/AuditForm.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SEO to AIO - Make the Shift | Rank4AI</title>
  <meta name="description" content="Google traffic is collapsing. Make the shift from SEO to AI Search Visibility. Free audit from Rank4AI.">
  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" href={`${base}/logo.png`}>
</head>
<body class="bg-white min-h-screen">
  <div class="max-w-[640px] mx-auto px-6 py-12">
    <img src={`${base}/logo.svg`} alt="Rank4AI" class="h-8 mx-auto mb-10">

    <div class="text-center mb-10">
      <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-4">The Shift</p>
      <h1 class="font-display text-3xl md:text-4xl text-teal leading-tight mb-4">SEO is Not Enough. AI Search is Here.</h1>
      <p class="text-text-muted leading-relaxed">Google organic clicks down 17%. Paid clicks down 68%. That traffic moved to AI search. We help UK businesses make the shift.</p>
    </div>

    <AuditForm />

    <p class="text-center text-xs text-text-muted mt-8">Rank4AI Ltd - Company 16584507 - <a href="/" class="underline">rank4ai.co.uk</a></p>
  </div>
</body>
</html>
