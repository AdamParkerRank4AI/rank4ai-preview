---
import Layout from '../../layouts/Layout.astro'
import library from '../../data/knowledge-library-full.json'

export function getStaticPaths() {
  return library
    .filter((p: any) => p.url.startsWith('/ai-search/'))
    .map((p: any) => ({
      params: { slug: p.slug.replace('ai-search/', '') },
      props: p
    }))
}

const { name, metaTitle, metaDesc, aiSummary, directAnswer, bodyContent, faqCount, youtubeUrl, layer } = Astro.props
const title = metaTitle || `${name} | Rank4AI`
const description = metaDesc || aiSummary || `${name} – AI search visibility information from Rank4AI.`
---
<Layout title={title} description={description}>
<section class="pt-12 pb-24">
  <div class="container-narrow">
    <p class="text-xs text-text-muted mb-4">
      <a href="/" class="hover:text-accent">Home</a> &rsaquo;
      <a href="/ai-search/" class="hover:text-accent">AI Search</a> &rsaquo;
      <span>{name}</span>
    </p>
    <h1 class="mb-6">{name}</h1>

    {directAnswer && (
      <div class="bg-off-white border-l-3 border-l-teal rounded-lg p-6 mb-8">
        <p class="text-[15px] text-text-muted leading-relaxed">{directAnswer}</p>
      </div>
    )}

    {bodyContent ? (
      <div class="prose max-w-none text-[17px] text-text-muted leading-relaxed" set:html={bodyContent} />
    ) : (
      <p class="text-[17px] text-text-muted leading-relaxed mb-5">{aiSummary || 'Content migrating from previous site.'}</p>
    )}

    {youtubeUrl && (
      <div class="my-8 aspect-video rounded-xl overflow-hidden">
        <iframe src={youtubeUrl.replace('youtu.be/', 'www.youtube.com/embed/').replace('watch?v=', 'embed/')} class="w-full h-full" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
      </div>
    )}
  </div>

  <div class="bg-off-white border-t border-border text-center py-16 px-10 mt-16">
    <h2 class="!text-2xl mb-4">Want us to check this for your business?</h2>
    <a href="/free-audit/" class="cta-primary">Get a Free AI Search Visibility Audit &rarr;</a>
  </div>
</section>
</Layout>
