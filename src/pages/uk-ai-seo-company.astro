      <p class="text-[15px] text-text-muted leading-relaxed"><a href="/free-audit/" class="link">Start with a free audit</a>.</p>
    </div>

    <div class="pt-8 border-t border-border">
      <h2 class="!text-xl mb-4">Related</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
