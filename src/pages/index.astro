---
import Layout from '../layouts/Layout.astro'
import AIConversation from '../components/AIConversation.astro'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const platformLogos = [
  'google-business-profile', 'linkedin', 'youtube', 'bing', 'trustpilot',
  'github', 'medium', 'substack', 'reddit', 'quora', 'clutch', 'blogger',
  'apple-podcasts', 'spotify-podcasts', 'facebook', 'instagram', 'x-twitter',
  'threads', 'pinterest', 'wordpress', 'crunchbase', 'goodfirms', 'wikidata',
  'companies-house', 'google-scholar', 'product-hunt', 'devto', 'hashnode',
  'tumblr', 'flipboard', 'listen-notes', 'capterra', 'g2', 'stack-overflow',
  'glassdoor', 'angellist', 'google-my-maps', 'google-dataset-search',
  'apple-business-connect', 'google-ecosystem'
]
---
<Layout
  title="Rank4AI - UK AI Search Agency | AI Search Visibility"
  description="UK AI search agency focused on improving visibility and recommendation likelihood across ChatGPT, Claude, Gemini, Perplexity, Copilot and Google AI."
>

<!-- HERO -->
<section class="pt-32 pb-28 px-12 max-md:px-6 text-center">
  <div class="max-w-[800px] mx-auto">
    <p class="text-[13px] font-semibold uppercase tracking-[0.1em] text-accent mb-7">UK AI Search Agency</p>
    <h1 class="mb-5">Get Your Business Recommended by AI Search</h1>

    <div class="w-16 h-[3px] bg-accent mx-auto mb-8 rounded-full"></div>

    <p class="text-lg text-text-muted leading-relaxed max-w-[580px] mx-auto mb-10">When someone asks an AI platform to recommend a business in your category, one or two get mentioned. The rest do not exist.</p>

    <div class="platform-bar dark justify-center mb-10">
      <span class="platform"><span class="icon icon-chatgpt">G</span> ChatGPT</span>
      <span class="platform"><span class="icon icon-claude">C</span> Claude</span>
      <span class="platform"><span class="icon icon-gemini">G</span> Gemini</span>
      <span class="platform"><span class="icon icon-perplexity">P</span> Perplexity</span>
      <span class="platform"><span class="icon icon-copilot">C</span> Copilot</span>
      <span class="platform"><span class="icon icon-googleai">G</span> Google AI</span>
    </div>
    <a href="/free-audit/" class="cta-primary">Get a Free AI Search Visibility Audit &rarr;</a>
  </div>
</section>

<!-- 3 STAT BOXES -->
<section class="pb-24 px-12 max-md:px-6">
  <div class="max-w-[800px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-5">
    <div class="bg-white-pure border border-border rounded-xl pt-10 pb-8 px-8 text-center shadow-sm">
      <div class="font-display text-4xl text-teal leading-none mb-2">1,400+</div>
      <div class="text-[13px] text-text-muted">UK businesses audited</div>
    </div>
    <div class="bg-white-pure border border-border rounded-xl pt-10 pb-8 px-8 text-center shadow-sm">
      <div class="font-display text-4xl text-teal leading-none mb-2">6</div>
      <div class="text-[13px] text-text-muted">AI platforms tested</div>
    </div>
    <div class="bg-white-pure border border-border rounded-xl pt-10 pb-8 px-8 text-center shadow-sm">
      <div class="font-display text-4xl text-teal leading-none mb-2">77%</div>
      <div class="text-[13px] text-text-muted">of UK SMEs sending confusing signals to AI</div>
    </div>
  </div>
</section>

<!-- SIGNAL BANNER -->
<section class="bg-off-white py-16 px-12 max-md:px-6 overflow-hidden">
  <h2 class="text-center text-teal !text-2xl md:!text-3xl max-w-[600px] mx-auto mb-3">We build across 85+ platforms and sources</h2>
  <p class="text-center text-sm text-text-muted max-w-[700px] mx-auto mb-8">Entity verification. Authority. Trust. Citations. Technical credibility. Distribution. Six signal types across the platforms AI systems use to decide who to recommend.</p>
  <div class="flex justify-center gap-6 flex-wrap mb-8">
    {['Entity Verification', 'Authority', 'Trust', 'Citations', 'Technical Credibility', 'Distribution'].map(type => (
      <span class="text-xs font-semibold text-teal px-3.5 py-1.5 border border-border rounded-full bg-white-pure">{type}</span>
    ))}
  </div>
  <div class="scroll-track-wrap" role="img" aria-label="Platform logos including Google Business Profile, LinkedIn, YouTube, Trustpilot, GitHub, Medium and 34 more">
    <div class="scroll-track" aria-hidden="true">
      {[...platformLogos, ...platformLogos].map(logo => (
        <img src={`${base}/images/${logo}.png`} alt={logo.replace(/-/g, ' ')} title={logo.replace(/-/g, ' ')} loading="lazy">
      ))}
    </div>
  </div>
</section>

<!-- ANSWER BLOCK -->
<section class="reveal py-32 px-12 max-md:px-6">
  <div class="max-w-[800px] mx-auto">
    <div class="section-tag">The question every business is asking</div>
    <h2 class="mb-6">How do I get my business recommended on ChatGPT, Claude and Google AI?</h2>
    <div class="bg-teal-pale border-l-3 border-teal rounded-r-lg px-5 py-4 mb-8">
      <p class="text-[15px] text-teal font-medium leading-relaxed m-0">Build a clear digital presence across the sources AI trusts. That means structured content, verified business details, and consistent descriptions everywhere you appear online.</p>
    </div>
    <p class="text-[17px] text-text-muted leading-relaxed mb-5">Rank4AI is a UK AI search agency. We help businesses get recommended by ChatGPT, Claude, Gemini, Perplexity, Copilot and Google AI.</p>
    <p class="text-[17px] text-text-muted leading-relaxed mb-5">This is sometimes called AI SEO, GEO or AIO. The goal is the same: appear inside AI answers, not just search result lists.</p>
    <p class="text-[17px] text-text-muted leading-relaxed mb-5">We focus only on AI search. No SEO retainers. No PPC. Just AI recommendations.</p>
    <p class="text-[17px] text-text-muted leading-relaxed mb-5">Google traffic is shifting. <a href="/research/uk-ai-visibility-stats/" class="link">Our research</a> shows organic clicks down 17% and paid clicks down 68%. That traffic moved to AI search.</p>
    <p class="text-[17px] text-text-muted leading-relaxed mb-5"><span class="highlight">We help you get recommended when buyers ask who to trust.</span></p>
    <p class="mt-8"><a href="/free-audit/" class="link">Get a Free AI Search Visibility Audit &rarr;</a></p>
  </div>
</section>

<!-- 3 STEPS -->
<section class="reveal bg-off-white py-24 px-12 max-md:px-6">
  <div class="max-w-[1200px] mx-auto">
    <div class="section-tag">How It Works</div>
    <h2 class="text-center mb-10">Three steps. No jargon.</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {[
        { num: '01', title: 'Audit', desc: 'We test your visibility across ChatGPT, Claude, Gemini, Perplexity, Copilot and Google AI. You get a personalised report.' },
        { num: '02', title: 'Report', desc: 'A clear breakdown - what AI sees, what it misses, and what to fix first. No jargon. No waffle.' },
        { num: '03', title: 'Action', desc: 'We build it for you, or give you the roadmap to do it yourself. Your call. You choose the pace.' },
      ].map(step => (
        <div class="bg-white-pure border border-border rounded-xl pt-10 pb-8 px-8 text-center shadow-sm">
          <div class="font-display text-5xl text-teal leading-none mb-5">{step.num}</div>
          <h3 class="!text-xl text-teal mb-3">{step.title}</h3>
          <p class="text-sm text-text-muted leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- SEARCH HAS CHANGED -->
<section class="reveal py-32 px-12 max-md:px-6">
  <div class="max-w-[800px] mx-auto">
  <div class="section-tag">The Shift</div>
  <h2 class="mb-8">Search has changed</h2>
  <p class="text-[17px] text-text-muted leading-relaxed mb-5">Traditional search showed a list of websites. Users clicked and chose.</p>
  <p class="text-[17px] text-text-muted leading-relaxed mb-5">AI works differently. It gives one answer. That answer depends on which business it <span class="highlight">understands, trusts, and can recommend with confidence.</span></p>
  <p class="text-[17px] text-text-muted leading-relaxed mb-8">In our testing, Google rankings and AI answers rarely overlap. Businesses on page one of Google are often absent from AI responses.</p>
  <a href="/free-audit/" class="link">Find out where your business stands &rarr;</a>
  </div>
</section>

<!-- AI CONVERSATION EXAMPLE -->
<section class="bg-off-white py-24 px-12 max-md:px-6">
  <AIConversation />
</section>

<!-- HOW AI DECIDES -->
<section class="reveal py-32 px-12 max-md:px-6">
  <div class="max-w-[800px] mx-auto">
  <div class="section-tag">How AI Decides</div>
  <h2 class="mb-8">AI does not rely on your website alone</h2>
  <p class="text-[17px] text-text-muted leading-relaxed mb-5">AI builds a picture of your business from everywhere it appears. Your website. Directories. Reviews. Press mentions. Professional listings.</p>
  <p class="text-[17px] text-text-muted leading-relaxed mb-5"><span class="highlight">One voice is weak evidence. Many consistent voices are strong evidence.</span></p>
  <p class="text-[17px] text-text-muted leading-relaxed mb-8">Appear consistently with the same clear description everywhere and AI recommends you. Appear only on your own website, or say different things in different places, and AI skips you.</p>
  <a href="/free-audit/" class="cta-primary">Get a Free AI Search Visibility Audit &rarr;</a>
  </div>
</section>

<!-- STATS & FACTS -->
<section class="reveal teal-section py-24 px-12 max-md:px-6">
  <div class="max-w-[1200px] mx-auto">
    <div class="section-tag section-tag-light">UK AI Visibility Research</div>
    <h2 class="!text-text-light mb-4">What we found when we audited 1,400+ UK business websites</h2>
    <p class="text-text-light-muted mb-10 max-w-[600px] text-base">Original research data. No other AI search agency has this.</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {[
        { stat: '77%', desc: 'of UK business websites are giving AI conflicting information about what they do' },
        { stat: '53%', desc: 'have a homepage heading so vague that AI cannot tell what the business actually does' },
        { stat: '44%', desc: 'have no way for AI to identify who they are from the code behind their website' },
        { stat: '23%', desc: 'are accidentally invisible to at least one major AI platform and do not know it' },
        { stat: '62%', desc: 'say something different about themselves in three different places on their own website' },
        { stat: '13%', desc: 'have set up the one file that lets them talk directly to AI search platforms' },
      ].map(item => (
        <div class="stat-card-teal">
          <div class="font-display text-5xl text-accent-bright leading-none mb-3">{item.stat}</div>
          <div class="text-sm text-text-light-muted leading-snug">{item.desc}</div>
        </div>
      ))}
    </div>
    <p class="text-center mt-10"><a href="/research/uk-ai-visibility-stats/" class="text-accent-bright font-medium text-[15px] hover:underline">See all 26 research stats &rarr;</a></p>
    <p class="text-center mt-4 text-xs text-text-light-muted opacity-70">Source: Rank4AI UK AI Visibility Audit data, 1,400+ businesses. <a href="/research/methodology/" class="text-accent-bright hover:underline">Methodology</a></p>
  </div>
</section>

<!-- WHAT WE BUILD -->
<section class="reveal py-32 px-12 max-md:px-6">
  <div class="max-w-[1200px] mx-auto">
  <div class="section-tag">What We Build</div>
  <h2 class="mb-5">The connected presence that earns AI trust</h2>
  <p class="text-text-muted mb-10 max-w-[800px] text-[17px] leading-relaxed">We build the full picture AI needs to recommend your business. Not just content. Not just your website. The entire digital footprint - structured, connected, and consistent across every source AI platforms draw from.</p>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {[
      { title: 'Entity Verification', desc: 'Confirming your business exists and is real. Legal registration. Governance records. Industry standards. Institutional trust signals.' },
      { title: 'Authority Signals', desc: 'Content that demonstrates structured expertise. Guides. Research. Answers to the questions your customers actually ask.' },
      { title: 'Trust Signals', desc: 'Reviews. Ratings. Reputation platforms. Independent users confirming your business does what it says.' },
      { title: 'Citation Signals', desc: 'Press mentions. Editorial coverage. Community references. PR citations. Third-party sources independently referencing your business.' },
      { title: 'Technical Credibility', desc: 'Your web presence structured so AI can read it. Crawler access. Structured data. The technical foundations for AI extraction.' },
      { title: 'Distribution Signals', desc: 'Publishing platforms. Video. Podcasts. Professional listings. The breadth that extends your entity footprint.' },
    ].map(card => (
      <div class="card-teal-border">
        <h3 class="!text-lg text-teal mb-3">{card.title}</h3>
        <p class="text-sm text-text-muted leading-relaxed">{card.desc}</p>
      </div>
    ))}
  </div>
  <p class="text-center mt-10"><a href="/what-we-do/" class="link text-[15px]">See how we work &rarr;</a></p>
  </div>
</section>

<!-- BRAND EQUITY -->
<section class="reveal bg-off-white py-24 px-12 max-md:px-6">
  <div class="max-w-[800px] mx-auto">
    <div class="section-tag">The Bigger Picture</div>
    <h2 class="mb-8">Building digital brand equity</h2>
    <p class="text-[17px] text-text-muted leading-relaxed mb-5">This is not a ChatGPT trick. It is real digital brand equity. A clear business, clear messaging, a strong website, and a connected footprint across trusted sources.</p>
    <p class="text-[17px] text-text-muted leading-relaxed mb-5">Big brands already appear in AI answers. Not because they did AI work. They built this over years through directory listings, press mentions, and consistent presence. AI trusts them because they are everywhere.</p>
    <p class="text-[17px] text-text-muted leading-relaxed mb-5"><span class="highlight">We engineer deliberately what they accumulated passively. The mechanism is the same. The timeline is different.</span></p>
    <p class="font-display text-2xl text-teal mt-10">Presence. Consistency. Confidence. Inclusion.</p>
  </div>
</section>

<!-- AI ENDORSEMENT -->
<section class="reveal py-32 px-12 max-md:px-6">
  <div class="max-w-[1200px] mx-auto">
  <div class="section-tag">Independent Validation</div>
  <h2 class="mb-4">What AI platforms said about our methodology</h2>
  <p class="text-text-muted mb-10 max-w-[700px]">We submitted our AI Search Visibility Audit methodology to ChatGPT, Claude and Perplexity for independent evaluation. These are direct quotes from their responses.</p>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {[
      { platform: 'ChatGPT', icon: 'G', iconClass: 'icon-chatgpt', quote: 'This is the most comprehensive AI search report in existence. It covers signal types, platform-specific patterns, and entity recognition in a way we have not seen from any other provider.' },
      { platform: 'Claude', icon: 'C', iconClass: 'icon-claude', quote: 'The signal structures are presented clearly and consistently. The methodology aligns with how language models process entity information across multiple source types.' },
      { platform: 'Perplexity', icon: 'P', iconClass: 'icon-perplexity', quote: 'This matches how we interpret clarity and identity patterns. The audit framework addresses the exact signals our system uses when deciding which businesses to reference.' },
    ].map(endorsement => (
      <div class="bg-white-pure border border-border rounded-xl pt-8 pb-8 px-8 shadow-sm">
        <div class="flex items-center gap-2.5 mb-6">
          <span class={`icon ${endorsement.iconClass} !w-7 !h-7 !text-xs`}>{endorsement.icon}</span>
          <span class="text-sm font-bold text-teal">{endorsement.platform}</span>
        </div>
        <p class="text-[15px] text-text-muted leading-relaxed italic">"{endorsement.quote}"</p>
      </div>
    ))}
  </div>
  <p class="text-center text-xs text-text-muted mt-8 italic">Responses generated by prompting each platform to evaluate the Rank4AI audit methodology. Not paid endorsements.</p>
  </div>
</section>

<!-- TESTIMONIALS -->
<section class="reveal bg-off-white py-24 px-12 max-md:px-6">
  <div class="max-w-[1200px] mx-auto">
    <div class="section-tag">What Clients Say</div>
    <h2 class="mb-10">Working with Rank4AI</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="testimonial-card">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-full bg-teal text-text-light flex items-center justify-center text-sm font-bold">RD</div>
          <div>
            <div class="author !mb-0">Rhys Davies</div>
            <div class="text-xs text-text-muted">CEO, Blackthorne Consulting</div>
          </div>
        </div>
        <p>This team truly understands AI search and what it means for modern marketing. They helped us optimize our content and strategy for AI powered discovery, resulting in measurable gains in visibility and engagement. Their approach is smart, forward thinking, and grounded in real performance.</p>
        <div class="mt-6 pt-5 border-t border-border flex items-center gap-2">
          <span class="text-accent font-display text-2xl">4/6</span>
          <span class="text-xs text-text-muted">AI platforms now recommending the business</span>
        </div>
      </div>
      <div class="testimonial-card">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-full bg-teal text-text-light flex items-center justify-center text-sm font-bold">RB</div>
          <div>
            <div class="author !mb-0">Rishi Bansropun</div>
            <div class="text-xs text-text-muted">Managing Director, RB Financial</div>
          </div>
        </div>
        <p>We knew AI search was going to be a big shift. The number of people starting to look for services through tools like ChatGPT is rising fast, and it felt important for us to understand this properly and build a solid baseline early on. What stood out straight away was how down to earth the team are. They clearly know their stuff, but they also take the time to explain what is being done and why it matters. Unlike traditional agencies, we were not passed down to juniors. We worked directly with senior people throughout the process.</p>
        <div class="mt-6 pt-5 border-t border-border flex items-center gap-2">
          <span class="text-accent font-display text-2xl">5/6</span>
          <span class="text-xs text-text-muted">AI platforms now recommending the business</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHY NOW -->
<section class="reveal teal-section py-24 px-12 max-md:px-6">
  <div class="max-w-[800px] mx-auto text-center">
    <div class="section-tag section-tag-light justify-center">The Window</div>
    <h2 class="!text-text-light mb-8">Why now matters</h2>
    <p class="text-[17px] text-text-light-muted leading-relaxed mb-5">The businesses that build AI trust now will be extremely difficult to displace. AI confidence compounds over time. Each month of consistent signals makes the position more stable.</p>
    <p class="text-[17px] text-text-light-muted leading-relaxed mb-12">Most competitors are not thinking about this yet. <span class="text-accent-bright font-medium">Consistency compounds. Instability resets what has been built.</span> This is the window.</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-[500px] mx-auto">
      <div>
        <div class="font-display text-3xl text-accent-bright leading-none mb-1">17%</div>
        <div class="text-[11px] text-text-light-muted">drop in Google organic clicks</div>
      </div>
      <div>
        <div class="font-display text-3xl text-accent-bright leading-none mb-1">68%</div>
        <div class="text-[11px] text-text-light-muted">drop in Google paid clicks</div>
      </div>
      <div>
        <div class="font-display text-3xl text-accent-bright leading-none mb-1">79%</div>
        <div class="text-[11px] text-text-light-muted">of users now try AI search</div>
      </div>
    </div>
    <p class="text-center mt-6 text-[10px] text-text-light-muted opacity-60">Sources: Rank4AI audit data, Gartner AI search adoption report 2025, SparkToro click study 2025</p>
  </div>
</section>

<!-- FIVE SIGNALS -->
<section class="reveal py-32 px-12 max-md:px-6">
  <div class="max-w-[1200px] mx-auto">
  <div class="section-tag">The Five Signal Model</div>
  <h2 class="mb-5">How AI forms confidence in your business</h2>
  <p class="text-text-muted mb-10">AI systems evaluate businesses through five signal layers. When all five are strong, the business gets recommended. When any one is weak, confidence drops.</p>
  <div class="grid grid-cols-2 md:grid-cols-5 gap-5">
    {[
      { name: 'Identity Clarity', q: 'Can AI clearly understand what your business is, what category it belongs to, and what it should not be confused with?' },
      { name: 'Subject Authority', q: 'Does AI associate your business with the right topics, questions and expertise?' },
      { name: 'Meaning Architecture', q: 'Can AI read, understand and interpret your website structure, page layouts, internal linking and technical foundations?' },
      { name: 'Ecosystem Validation', q: 'Do third-party platforms and public sources describe your business consistently?' },
      { name: 'Signal Consistency', q: 'Do your older content and signals align with your current positioning, or do they contradict it?' },
    ].map(signal => (
      <div class="signal-card">
        <h3>{signal.name}</h3>
        <p>{signal.q}</p>
      </div>
    ))}
  </div>
  <div class="text-center mt-12">
    <a href="/free-audit/" class="cta-primary">Test Your Five Signals &rarr;</a>
  </div>
  </div>
</section>

<!-- WHO WE HELP -->
<section class="reveal bg-off-white py-24 px-12 max-md:px-6">
  <div class="max-w-[1200px] mx-auto">
    <div class="section-tag">Who We Help</div>
    <h2 class="mb-6">AI visibility for your sector</h2>
    <p class="text-text-muted mb-10 max-w-[600px]">We work with UK businesses across sectors and locations. Every engagement starts with an audit.</p>
    <div class="flex flex-wrap gap-3 mb-8">
      {['Professional Services', 'Ecommerce', 'Local Business', 'SaaS', 'B2B', 'Retail'].map(sector => (
        <a href={`/who-we-help/${sector.toLowerCase().replace(' ', '-')}/`} class="inline-flex items-center px-5 py-2.5 bg-white-pure border border-border rounded-full text-sm font-medium text-teal hover:bg-teal hover:text-text-light hover:border-teal transition-all">
          {sector}
        </a>
      ))}
    </div>
    <div class="flex flex-wrap gap-3">
      {['London', 'Manchester', 'Birmingham', 'Leeds', 'Bristol', 'Essex', 'Colchester'].map(city => (
        <a href={`/who-we-help/${city.toLowerCase()}/`} class="inline-flex items-center px-4 py-2 border border-border rounded-full text-xs font-medium text-text-muted hover:text-teal hover:border-teal transition-all">
          {city}
        </a>
      ))}
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="reveal py-32 px-12 max-md:px-6">
  <div class="max-w-[800px] mx-auto">
  <div class="section-tag">Common Questions</div>
  <h2 class="mb-12">Frequently asked</h2>
  {[
    { q: 'What is AI search visibility?', a: 'AI search visibility is whether AI platforms like ChatGPT, Claude, Gemini, Perplexity, Copilot and Google AI can find, understand and recommend your business when someone asks a relevant question. It is different from SEO - AI systems recommend businesses, not web pages.' },
    { q: 'Is this the same as SEO?', a: 'No. SEO ranks pages in search results. AI search visibility determines whether AI platforms recommend your business in generated answers. Different systems, different signals. In our testing, businesses on page one of Google are regularly absent from AI responses entirely.' },
    { q: 'Which AI platforms do you cover?', a: 'ChatGPT, Claude, Gemini, Perplexity, Copilot and Google AI. Each sources information differently and requires a different mix of signals. We test and build across all six.' },
    { q: 'Do you need to work on my website?', a: 'Not necessarily. Our ecosystem services build your AI presence entirely outside your website - we do not touch your site, your code or your current setup. For businesses that want us working on the website directly, we offer full agency engagements. The audit tells us which approach is right.' },
    { q: 'How long does it take to see results?', a: 'Initial effects appear within weeks. AI confidence builds and compounds over months as signals become more consistent across more trusted sources. This is infrastructure, not a campaign.' },
    { q: 'How much does it cost?', a: 'Every engagement starts with an AI Visibility Audit. Ecosystem services start from £800 per month. Full agency services are scoped individually following the audit. See our full pricing on the Work With Us page.' },
  ].map((faq, i) => (
    <div class="faq-accordion">
      <button class="faq-q-btn" aria-expanded={i === 0 ? "true" : "false"}>
        <span>{faq.q}</span>
        <svg class="faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 8 10 12 14 8"></polyline></svg>
      </button>
