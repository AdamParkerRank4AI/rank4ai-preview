    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.faq-q-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      document.querySelectorAll('.faq-a-panel').forEach(p => p.classList.remove('open'));
      if (!expanded) {
        btn.setAttribute('aria-expanded', 'true');
        btn.nextElementSibling?.classList.add('open');
      }
    });
  });
</script>

