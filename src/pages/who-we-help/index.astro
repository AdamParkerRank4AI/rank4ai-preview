---
import Breadcrumbs from '../../components/Breadcrumbs.astro'
import Layout from '../../layouts/Layout.astro'
import sectors from '../../data/sectors.json'
import cities from '../../data/cities.json'

const mainSectors = sectors.filter((s: any) => ['professional-services','ecommerce','local-business','saas','b2b','retail'].includes(s.slug))
const professions = [
  { slug: 'accountants', name: 'Accountants' },
  { slug: 'solicitors', name: 'Solicitors' },
  { slug: 'dentists', name: 'Dentists' },
  { slug: 'estate-agents', name: 'Estate Agents' },
  { slug: 'architects', name: 'Architects' },
  { slug: 'financial-advisors', name: 'Financial Advisors' },
  { slug: 'restaurants', name: 'Restaurants' },
  { slug: 'hospitality', name: 'Hotels & Hospitality' },
  { slug: 'recruitment', name: 'Recruitment' },
  { slug: 'tradespeople', name: 'Tradespeople' },
  { slug: 'healthcare', name: 'Healthcare' },
  { slug: 'property', name: 'Property' },
  { slug: 'education', name: 'Education & Training' },
  { slug: 'technology', name: 'Technology' },
  { slug: 'marketing-agencies', name: 'Marketing Agencies' },
]
---
<Layout title="AI Search Visibility by Industry & Location | Rank4AI" description="AI search visibility for UK businesses. 21 sectors and 7 cities. We help your industry get recommended by AI.">
<section class="pt-12 pb-24 reveal">
  <div class="container">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Who We Help' }
    ]} />

    <p class="section-tag">Who We Help</p>
    <h1 class="mb-6">AI Search Visibility for Your Sector</h1>
    <p class="text-[17px] text-text-muted leading-relaxed mb-10 max-w-[700px]">We work with UK businesses across every sector and profession. The same five signal layers apply - but how they manifest differs by industry. Each page shows the specific AI search challenges and opportunities for your business type.</p>

    <h2 class="mb-6">By Sector</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
      {mainSectors.map((sector: any) => (
        <a href={`/who-we-help/${sector.slug}/`} class="card group">
          <h3 class="!text-lg text-teal mb-2 group-hover:text-accent transition-colors">{sector.name}</h3>
          <p class="text-sm text-text-muted leading-relaxed">{sector.desc}</p>
        </a>
      ))}
    </div>

    <h2 class="mb-6">By Profession & Industry</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3 mb-12">
      {professions.map(p => (
        <a href={`/who-we-help/${p.slug}/`} class="bg-off-white border border-border rounded-xl px-5 py-4 text-sm font-medium text-text text-center hover:bg-teal hover:text-text-light hover:border-teal transition-all">
          {p.name}
        </a>
      ))}
    </div>

    <h2 class="mb-6">By Location</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-3 mb-16">
      {cities.map((city: any) => (
        <a href={`/who-we-help/${city.slug}/`} class="bg-off-white border border-border rounded-xl px-5 py-4 text-sm font-medium text-text text-center hover:bg-teal hover:text-text-light hover:border-teal transition-all">
          {city.name}
        </a>
      ))}
    </div>
  </div>

    <!-- Internal links -->
    <div class="mt-12 pt-8 border-t border-border">
      <h2 class="!text-xl mb-4">Related</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <a href="/what-we-do/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">Our Services</span></a>
        <a href="/research/uk-ai-visibility-stats/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">UK AI Statistics</span></a>
        <a href="/free-audit/" class="card group text-sm"><span class="font-medium text-accent">Get a Free Audit &rarr;</span></a>

      </div>
    </div>
  </div>

  <div class="bg-off-white border-t border-border text-center py-24 px-10">
    <h2 class="mb-4">Find out if AI can see your business</h2>
    <a href="/free-audit/" class="cta-primary">Get a Free AI Search Visibility Audit &rarr;</a>
  </div>
</section>
</Layout>
