---
import Layout from '../../layouts/Layout.astro'
import sectors from '../../data/sectors.json'
import cities from '../../data/cities.json'

export function getStaticPaths() {
  const sectorPaths = sectors.map((s: any) => ({
    params: { slug: s.slug },
    props: { type: 'sector', name: s.name, h1: s.h1, desc: s.desc }
  }))
  const cityPaths = cities.map((c: any) => ({
    params: { slug: c.slug },
    props: { type: 'city', name: c.name, h1: c.h1, desc: `AI search visibility agency in ${c.name}. We help ${c.name} businesses get recommended by ChatGPT, Claude, Gemini, Perplexity, Copilot and Google AI.` }
  }))
  return [...sectorPaths, ...cityPaths]
}

const { type, name, h1, desc } = Astro.props
const metaTitle = type === 'city'
  ? `${h1} | Rank4AI`
  : `${h1} | Rank4AI`
const metaDesc = type === 'city'
  ? `AI search visibility agency in ${name}. Rank4AI helps ${name} businesses get recommended by ChatGPT, Claude, Gemini, Perplexity, Copilot and Google AI.`
  : `${h1}. Get recommended by ChatGPT, Claude, Gemini, Perplexity, Copilot and Google AI. Free audit from Rank4AI.`
---
<Layout title={metaTitle} description={metaDesc}>

<section class="pt-12 pb-24 reveal">
  <div class="container-narrow">
    <p class="section-tag">{type === 'city' ? 'By Location' : 'By Sector'}</p>
    <h1 class="mb-6">{h1}</h1>
    <p class="text-[17px] text-text-muted leading-relaxed mb-5">{desc}</p>

    <p class="text-[17px] text-text-muted leading-relaxed mb-5">Rank4AI is a UK based AI search agency focused on improving visibility and recommendation likelihood across ChatGPT, Claude, Gemini, Perplexity, Copilot and Google AI.</p>

    {type === 'sector' && (
      <>
        <h2 class="mt-12 mb-4">The Challenge for {name}</h2>
        <p class="text-[17px] text-text-muted leading-relaxed mb-5">When someone asks an AI platform to recommend a {name.toLowerCase()} business, one or two get mentioned. The rest do not exist. That recommendation is not based on Google rankings – it is based on which business the AI system understands clearly, trusts consistently, and can confidently recommend.</p>
        <p class="text-[17px] text-text-muted leading-relaxed mb-5">In our UK testing, the overlap between strong Google rankings and AI-generated answers is consistently low. {name} businesses ranking on page one of Google are regularly absent from AI responses entirely.</p>

        <h2 class="mt-12 mb-4">What We Do</h2>
        <p class="text-[17px] text-text-muted leading-relaxed mb-5">We build the connected digital presence that earns AI trust for {name.toLowerCase()} businesses. Your website structured so AI can read it. Your digital footprint across directories, review platforms, publications and professional listings. Your consistency – the same clear positioning everywhere.</p>

        <h2 class="mt-12 mb-4">The Five Signals</h2>
        <p class="text-[17px] text-text-muted leading-relaxed mb-5">AI systems evaluate {name.toLowerCase()} businesses through five signal layers: Identity Clarity, Subject Authority, Meaning Architecture, Ecosystem Validation and Signal Consistency. Our audit measures all five for your business specifically.</p>
      </>
    )}

    {type === 'city' && (
      <>
        <h2 class="mt-12 mb-4">AI Search Visibility in {name}</h2>
        <p class="text-[17px] text-text-muted leading-relaxed mb-5">When someone in {name} asks ChatGPT, Gemini or Perplexity to recommend a local business, AI platforms build their answer from multiple sources. Your website, your directories, your reviews, your press mentions, your professional listings.</p>
        <p class="text-[17px] text-text-muted leading-relaxed mb-5">A business that appears consistently across trusted sources with the same clear description of what it does gets recommended. A business that only exists on its own website, or describes itself differently in different places, gets skipped.</p>

        <h2 class="mt-12 mb-4">How We Help {name} Businesses</h2>
        <p class="text-[17px] text-text-muted leading-relaxed mb-5">Every engagement starts with an AI Search Visibility Audit. We test your current visibility across all six major AI platforms, identify the gaps across all five signal layers, and tell you exactly what the right starting point is.</p>
        <p class="text-[17px] text-text-muted leading-relaxed mb-5">From there, we either build your presence across the web without touching your site (ecosystem services from £800/mo) or work on your website directly alongside the full ecosystem build (full agency from £1,500/mo).</p>
      </>
    )}
  </div>

  <div class="bg-off-white border-t border-border text-center py-24 px-10 mt-16">
    <h2 class="mb-4">Find out if AI can see your business</h2>
    <p class="text-[17px] text-text-muted mb-10 max-w-[500px] mx-auto">Every engagement starts with an audit across all six AI platforms.</p>
    <a href="/free-audit/" class="cta-primary">Get a Free AI Search Visibility Audit &rarr;</a>
  </div>
</section>

</Layout>
