---
import Layout from '../../layouts/Layout.astro'
import Breadcrumbs from '../../components/Breadcrumbs.astro'
import AuthorBox from '../../components/AuthorBox.astro'
import blogs from '../../data/blogs.json'

export function getStaticPaths() {
  return blogs.map((post: any) => ({
    params: { slug: post.slug },
    props: post
  }))
}

const { title, slug, metaTitle, metaDesc, primaryQuestion, directAnswer, bodyContent, cardExcerpt, author, publishedAt, updatedAt, youtubeUrl, spotifyUrl, faqCount, governanceCluster } = Astro.props

const pageTitle = metaTitle || `${title} | Rank4AI`
const pageDesc = metaDesc || cardExcerpt || `${title} - AI search visibility insights from Rank4AI.`
const pubDate = publishedAt ? new Date(publishedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) : ''
const updDate = updatedAt ? new Date(updatedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) : ''
---
<Layout title={pageTitle} description={pageDesc}>

<article class="pt-12 pb-24">
  <div class="container-narrow">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Blog', href: '/blog/' },
      { label: title }
    ]} />

    {governanceCluster && (
      <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-4 mt-6">{governanceCluster}</p>
    )}

    <h1 class="mb-4">{title}</h1>

    <!-- Author + Dates -->
    <div class="flex flex-wrap gap-4 text-sm text-text-muted mb-8">
      {author && <span>By <span class="font-medium text-teal">{author}</span></span>}
      {pubDate && <span>Published {pubDate}</span>}
      {updDate && <span>Updated {updDate}</span>}
    </div>

    <!-- Direct Answer / Answer Capsule -->
    {directAnswer && (
      <div class="bg-off-white border-l-3 border-l-teal rounded-lg p-6 mb-8">
        <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-2">Quick Answer</p>
        <p class="text-[15px] text-text-muted leading-relaxed">{directAnswer}</p>
      </div>
    )}

    <!-- YouTube embed -->
    {youtubeUrl && (
      <div class="my-8 aspect-video rounded-xl overflow-hidden">
        <iframe
          src={youtubeUrl.replace('youtu.be/', 'www.youtube.com/embed/').replace('watch?v=', 'embed/')}
          class="w-full h-full"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    )}

    <!-- Image -->
    <img src="/images/content/ai-search-signals.svg" alt="AI search visibility signals" class="w-full rounded-xl mb-8" loading="lazy">

    <!-- Body content -->
    {bodyContent ? (
      <div class="prose max-w-none text-[17px] text-text-muted leading-relaxed" set:html={bodyContent} />
    ) : (
      <p class="text-[17px] text-text-muted leading-relaxed mb-5">{cardExcerpt || 'Content migrating.'}</p>
    )}

    <!-- Spotify embed -->
    {spotifyUrl && (
      <div class="my-8">
        <iframe
          src={`https://open.spotify.com/embed/episode/${spotifyUrl.split('/').pop()}`}
          width="100%"
          height="152"
          frameborder="0"
          allow="encrypted-media"
          loading="lazy"
          class="rounded-xl"
        ></iframe>
      </div>
    )}

    <!-- About Rank4AI -->
    <div class="mt-12 pt-8 border-t border-border mb-8">
      <h2 class="!text-xl mb-4">About Rank4AI</h2>
      <p class="text-[15px] text-text-muted leading-relaxed mb-3">Rank4AI is a UK AI search agency. We help businesses get recommended by ChatGPT, Claude, Gemini, Perplexity, Copilot and Google AI. We have audited over 1,400 UK businesses and published original research on AI search visibility patterns.</p>
      <p class="text-[15px] text-text-muted leading-relaxed">Every engagement starts with a free audit across all six AI platforms. <a href="/free-audit/" class="link">Request yours here</a>.</p>
    </div>

    <!-- Internal links -->
    <div class="pt-8 border-t border-border">
      <h2 class="!text-xl mb-4">Related</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <a href="/learn/guides/complete-guide-ai-search/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">Complete Guide to AI Search Visibility</span></a>
        <a href="/about/five-signal-framework/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">The Five Signal Model</span></a>
        <a href="/research/uk-ai-visibility-stats/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">UK AI Visibility Statistics</span></a>
        <a href="/what-we-do/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">Our Services</span></a>
      </div>
    </div>

    <!-- Author box -->
    <AuthorBox name={author || "Adam Parker"} role="AI Search Visibility Specialist" dateModified={updDate || pubDate} />
  </div>

  <!-- CTA -->
  <div class="bg-off-white border-t border-border text-center py-16 px-10 mt-16">
    <h2 class="!text-2xl mb-4">Want us to check this for your business?</h2>
    <a href="/free-audit/" class="cta-primary">Get a Free AI Search Visibility Audit &rarr;</a>
  </div>
</article>

<!-- Article Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": pageDesc,
  "author": { "@type": "Person", "name": author || "Adam Parker" },
  "publisher": { "@type": "Organization", "name": "Rank4AI", "url": "https://www.rank4ai.co.uk" },
  "datePublished": publishedAt || undefined,
  "dateModified": updatedAt || publishedAt || undefined,
  "url": `https://www.rank4ai.co.uk/blog/${slug}/`
})} />

</Layout>
