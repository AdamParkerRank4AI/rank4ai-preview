---
import Layout from '../layouts/Layout.astro'
---
<Layout title="Page Not Found | Rank4AI" description="The page you are looking for does not exist." noindex={true}>

<section class="py-32 px-12 max-md:px-6 text-center">
  <div class="max-w-[600px] mx-auto">
    <p class="font-display text-8xl text-teal opacity-20 mb-6">404</p>
    <h1 class="!text-3xl mb-4">Page not found</h1>
    <p class="text-[17px] text-text-muted leading-relaxed mb-10">The page you are looking for does not exist or has been moved.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/" class="cta-primary">Go to homepage &rarr;</a>
      <a href="/free-audit/" class="cta-primary !bg-transparent !text-teal border border-border hover:!bg-off-white">Get a free audit &rarr;</a>
    </div>
  </div>
</section>

</Layout>
