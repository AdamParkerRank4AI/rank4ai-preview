---
import Breadcrumbs from '../../components/Breadcrumbs.astro'
import Layout from '../../layouts/Layout.astro'
---
<Layout title="Resources & Downloads | Rank4AI" description="Free downloadable guides, tools, and resources for AI search visibility from Rank4AI.">
<section class="pt-12 pb-24 reveal">
  <div class="container-narrow">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Resources' }
    ]} />

    <p class="section-tag">Resources</p>
    <h1 class="mb-6">Resources</h1>
    <p class="text-[17px] text-text-muted leading-relaxed mb-10">Free guides, tools, and resources to help you understand and build AI search visibility.</p>
    <div class="space-y-6">
      <a href="/learn/guides/" class="card block group">
        <h3 class="!text-lg text-teal mb-2">Guides</h3>
        <p class="text-sm text-text-muted">In-depth guides covering AI search visibility, GEO, ChatGPT optimisation and more.</p>
      </a>
      <a href="/learn/tools/ai-visibility-checker/" class="card block group">
        <h3 class="!text-lg text-teal mb-2">AI Visibility Checker</h3>
        <p class="text-sm text-text-muted">Quick free check of your AI search visibility.</p>
      </a>
      <a href="/learn/tools/llms-txt-generator/" class="card block group">
        <h3 class="!text-lg text-teal mb-2">Free llms.txt Generator</h3>
        <p class="text-sm text-text-muted">Build your llms.txt file in 2 minutes.</p>
      </a>
      <a href="/learn/glossary/" class="card block group">
        <h3 class="!text-lg text-teal mb-2">AI Search Glossary</h3>
        <p class="text-sm text-text-muted">50+ AI search terms explained.</p>
      </a>
      <a href="/podcast/" class="card block group">
        <h3 class="!text-lg text-teal mb-2">Podcast – AI Search Explained</h3>
        <p class="text-sm text-text-muted">Listen on Apple Podcasts, Spotify, and all major platforms.</p>
      </a>
    </div>
  </div>
</section>
</Layout>
