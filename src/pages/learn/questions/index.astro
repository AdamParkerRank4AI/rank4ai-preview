---
import Breadcrumbs from '../../../components/Breadcrumbs.astro'
import Layout from '../../../layouts/Layout.astro'
import questions from '../../../data/questions.json'

const categories = [...new Set(questions.map((q: any) => q.category).filter(Boolean))].sort()
const grouped: Record<string, any[]> = {}
for (const q of questions) {
  const cat = (q as any).category || 'Other'
  if (!grouped[cat]) grouped[cat] = []
  grouped[cat].push(q)
}
---
<Layout title="AI Search Questions and Answers | Rank4AI" description="285 AI search questions answered. The most comprehensive library of AI search visibility Q&A online.">
<section class="pt-12 pb-24">
  <div class="container">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Learn', href: '/learn/' },
      { label: 'Questions' }
    ]} />

    <p class="section-tag">Questions</p>
    <h1 class="mb-4">AI Search Questions and Answers</h1>
    <p class="text-[17px] text-text-muted leading-relaxed mb-4">{questions.length} questions about AI search visibility, answered clearly.</p>
    <p class="text-sm text-text-muted mb-10">Covering AI platforms, AI SEO, technical visibility, industry-specific questions, citations and more.</p>
    <div class="flex flex-wrap gap-2 mb-12">
      {categories.map((cat: string) => (
        <span class="text-xs font-semibold text-teal px-3 py-1.5 border border-border rounded-full bg-white">{cat} ({grouped[cat]?.length || 0})</span>
      ))}
    </div>
    {Object.entries(grouped).sort().map(([cat, qs]) => (
      <div class="mb-12">
        <h2 class="!text-xl mb-4">{cat} <span class="text-sm text-text-muted font-body">({(qs as any[]).length})</span></h2>
        <div class="space-y-2">
          {(qs as any[]).map((q) => (
            <a href={`/learn/questions/${q.slug}/`} class="block p-3 rounded-lg hover:bg-off-white transition-colors text-[15px] text-text hover:text-accent">
              {q.question}
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>

    <!-- Internal links -->
    <div class="mt-12 pt-8 border-t border-border">
      <h2 class="!text-xl mb-4">Related</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <a href="/learn/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">All Resources</span></a>
        <a href="/learn/guides/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">All Guides</span></a>
        <a href="/about/five-signal-framework/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">The Five Signal Model</span></a>
        <a href="/free-audit/" class="card group text-sm"><span class="font-medium text-accent">Get a Free Audit &rarr;</span></a>

      </div>
    </div>
  </div>

  <div class="bg-off-white border-t border-border text-center py-16 px-10 mt-16">
    <h2 class="!text-2xl mb-4">Want us to check this for your business?</h2>
    <a href="/free-audit/" class="cta-primary">Get a Free AI Search Visibility Audit &rarr;</a>
  </div>
</section>
</Layout>
