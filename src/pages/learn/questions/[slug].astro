---
import Layout from '../../../layouts/Layout.astro'
import questions from '../../../data/questions.json'

export function getStaticPaths() {
  return questions.map((q: any) => ({
    params: { slug: q.slug },
    props: q
  }))
}

const { question, slug, category, signalCategory, metaTitle, metaDesc, conciseAnswer, fullAnswer, youtubeUrl, spotifyUrl, podcastUrl, podcastEmbedId, updatedAt } = Astro.props

const pageTitle = metaTitle || `${question} | Rank4AI`
const pageDesc = metaDesc || conciseAnswer || `${question} — answered by Rank4AI.`
const updated = updatedAt ? new Date(updatedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) : ''
---
<Layout title={pageTitle} description={pageDesc}>

<article class="pt-12 pb-24">
  <div class="container-narrow">
    <p class="text-xs text-text-muted mb-4">
      <a href="/" class="hover:text-accent">Home</a> &rsaquo;
      <a href="/learn/questions/" class="hover:text-accent">Questions</a> &rsaquo;
      <span class="truncate">{question.substring(0, 50)}...</span>
    </p>

    <div class="flex flex-wrap gap-2 mb-4">
      {category && <span class="text-[11px] font-semibold uppercase tracking-widest text-accent">{category}</span>}
      {signalCategory && <span class="text-[11px] font-semibold uppercase tracking-widest text-text-muted">· {signalCategory}</span>}
    </div>

    <h1 class="!text-3xl md:!text-4xl mb-6">{question}</h1>

    {updated && <p class="text-sm text-text-muted mb-8">Updated {updated}</p>}

    <!-- Concise answer -->
    {conciseAnswer && (
      <div class="bg-off-white border-l-3 border-l-teal rounded-lg p-6 mb-8">
        <p class="text-[15px] text-teal font-medium mb-2">Quick Answer</p>
        <p class="text-[15px] text-text-muted leading-relaxed">{conciseAnswer}</p>
      </div>
    )}

    <!-- YouTube -->
    {youtubeUrl && (
      <div class="my-8 aspect-video rounded-xl overflow-hidden">
        <iframe src={youtubeUrl.replace('youtu.be/', 'www.youtube.com/embed/').replace('watch?v=', 'embed/')} class="w-full h-full" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
      </div>
    )}

    <!-- Full answer -->
    {fullAnswer ? (
      <div class="prose max-w-none text-[17px] text-text-muted leading-relaxed [&_h2]:font-display [&_h2]:text-teal [&_h2]:text-2xl [&_h2]:mt-10 [&_h2]:mb-4 [&_h3]:font-display [&_h3]:text-teal [&_h3]:text-xl [&_h3]:mt-8 [&_h3]:mb-3 [&_p]:mb-5 [&_ul]:mb-5 [&_ol]:mb-5 [&_li]:mb-2 [&_a]:text-accent [&_a:hover]:underline [&_strong]:text-teal" set:html={fullAnswer} />
    ) : (
      <p class="text-[17px] text-text-muted leading-relaxed">{conciseAnswer}</p>
    )}

    <!-- Podcast -->
    {podcastEmbedId && (
      <div class="my-8">
        <iframe src={`https://www.buzzsprout.com/2436836/${podcastEmbedId}?client_source=small_player&iframe=true`} width="100%" height="200" frameborder="0" scrolling="no" class="rounded-xl" loading="lazy"></iframe>
      </div>
    )}
  </div>

  <div class="bg-off-white border-t border-border text-center py-16 px-10 mt-16">
    <h2 class="!text-2xl mb-4">Want us to check this for your business?</h2>
    <a href="/free-audit/" class="cta-primary">Get a Free AI Search Visibility Audit &rarr;</a>
  </div>
</article>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{ "@type": "Question", "name": question, "acceptedAnswer": { "@type": "Answer", "text": conciseAnswer || fullAnswer?.substring(0, 300) || '' }}]
})} />

</Layout>
