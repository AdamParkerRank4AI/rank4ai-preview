---
import Layout from '../../../layouts/Layout.astro'
import Breadcrumbs from '../../../components/Breadcrumbs.astro'
import AuthorBox from '../../../components/AuthorBox.astro'
import questions from '../../../data/questions.json'

export function getStaticPaths() {
  return questions.map((q: any) => ({
    params: { slug: q.slug },
    props: q
  }))
}

const { question, slug, category, signalCategory, metaTitle, metaDesc, conciseAnswer, fullAnswer, youtubeUrl, spotifyUrl, podcastUrl, podcastEmbedId, updatedAt } = Astro.props

const pageTitle = metaTitle || `${question} | Rank4AI`
const pageDesc = metaDesc || conciseAnswer || `${question} - answered by Rank4AI.`
const updated = updatedAt ? new Date(updatedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) : ''
---
<Layout title={pageTitle} description={pageDesc}>

<article class="pt-12 pb-24">
  <div class="container-narrow">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Learn', href: '/learn/' },
      { label: 'Questions', href: '/learn/questions/' },
      { label: question.length > 50 ? question.substring(0, 50) + '...' : question }
    ]} />

    <div class="flex flex-wrap gap-2 mb-4 mt-6">
      {category && <span class="text-[11px] font-semibold uppercase tracking-widest text-accent">{category}</span>}
      {signalCategory && <span class="text-[11px] font-semibold uppercase tracking-widest text-text-muted">- {signalCategory}</span>}
    </div>

    <h1 class="!text-3xl md:!text-4xl mb-6">{question}</h1>

    {updated && <p class="text-sm text-text-muted mb-8">Updated {updated}</p>}

    <!-- Concise answer / Answer capsule -->
    {conciseAnswer && (
      <div class="bg-off-white border-l-3 border-l-teal rounded-lg p-6 mb-8">
        <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-2">Quick Answer</p>
        <p class="text-[15px] text-text-muted leading-relaxed">{conciseAnswer}</p>
      </div>
    )}

    <!-- YouTube -->
    {youtubeUrl && (
      <div class="my-8 aspect-video rounded-xl overflow-hidden">
        <iframe src={youtubeUrl.replace('youtu.be/', 'www.youtube.com/embed/').replace('watch?v=', 'embed/')} class="w-full h-full" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
      </div>
    )}

    <!-- Image -->
    <img src="/images/content/ai-platforms.svg" alt="AI search platforms" class="w-full rounded-xl mb-8" loading="lazy">

    <!-- Full answer -->
    {fullAnswer ? (
      <div class="prose max-w-none text-[17px] text-text-muted leading-relaxed" set:html={fullAnswer} />
    ) : (
      <p class="text-[17px] text-text-muted leading-relaxed">{conciseAnswer}</p>
    )}

    <!-- Podcast -->
    {podcastEmbedId && (
      <div class="my-8">
        <iframe src={`https://www.buzzsprout.com/2436836/${podcastEmbedId}?client_source=small_player&iframe=true`} width="100%" height="200" frameborder="0" scrolling="no" class="rounded-xl" loading="lazy"></iframe>
      </div>
    )}

    <!-- Internal links -->
    <div class="mt-12 pt-8 border-t border-border">
      <h2 class="!text-xl mb-4">Related</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <a href="/learn/guides/complete-guide-ai-search/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">Complete Guide to AI Search Visibility</span></a>
        <a href="/about/five-signal-framework/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">The Five Signal Model</span></a>
        <a href="/learn/questions/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">All AI Search Questions ({questions.length})</span></a>
        <a href="/free-audit/" class="card group text-sm"><span class="font-medium text-accent">Get a Free AI Search Visibility Audit &rarr;</span></a>
      </div>
    </div>

    <!-- Author -->
    <AuthorBox name="Adam Parker" role="AI Search Visibility Specialist" dateModified={updated} />
  </div>

  <div class="bg-off-white border-t border-border text-center py-16 px-10 mt-16">
    <h2 class="!text-2xl mb-4">Want us to check this for your business?</h2>
    <a href="/free-audit/" class="cta-primary">Get a Free AI Search Visibility Audit &rarr;</a>
  </div>
</article>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{ "@type": "Question", "name": question, "acceptedAnswer": { "@type": "Answer", "text": conciseAnswer || (fullAnswer ? fullAnswer.substring(0, 500) : '') }}]
})} />

</Layout>
