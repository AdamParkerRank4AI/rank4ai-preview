---
import Layout from '../../../layouts/Layout.astro'

const guides = [
  { href: '/learn/guides/complete-guide-ai-search/', title: 'Complete Guide to AI Search Visibility', desc: 'The definitive guide to understanding and building AI search visibility.', tag: 'Flagship' },
  { href: '/learn/guides/geo/', title: 'The Master Guide to GEO', desc: 'Generative Engine Optimisation explained.', tag: 'Flagship' },
  { href: '/learn/guides/get-cited-chatgpt/', title: 'How to Get Cited by ChatGPT', desc: 'Practical citation strategies for ChatGPT.', tag: 'Flagship' },
  { href: '/learn/guides/chatgpt-seo/', title: 'ChatGPT SEO – Complete UK Guide', desc: 'How to get your business recommended by ChatGPT.' },
  { href: '/learn/guides/perplexity-seo/', title: 'How to Rank in Perplexity', desc: 'Perplexity SEO guide – real-time crawler, explicit citations.' },
  { href: '/learn/guides/copilot-optimisation/', title: 'How to Appear in Microsoft Copilot', desc: 'Copilot visibility via Bing + LinkedIn.' },
  { href: '/learn/guides/claude-optimisation/', title: 'How to Appear in Claude AI', desc: 'Claude values verifiable entity definition above all.' },
  { href: '/learn/guides/searchgpt/', title: 'SearchGPT Optimisation', desc: 'OpenAI\'s search product – uses Bing as primary data source.' },
  { href: '/learn/guides/google-ai-mode/', title: 'Google AI Mode Optimisation', desc: 'The new AI-powered search tab replacing traditional results.' },
  { href: '/learn/guides/google-ai-overview-ranking-factors/', title: 'Google AI Overview Ranking Factors', desc: 'What determines citation in AI Overviews.' },
  { href: '/learn/guides/geo-vs-seo/', title: 'GEO vs SEO – Complete Comparison', desc: 'The key differences between GEO and traditional SEO.' },
  { href: '/learn/guides/entity-seo-for-ai/', title: 'Entity SEO for AI Search', desc: 'How entity authority drives AI recommendations.' },
  { href: '/learn/guides/structured-data-for-ai/', title: 'Structured Data for AI Search', desc: '2.5x higher citation chance with proper schema.' },
  { href: '/learn/guides/aeo/', title: 'Answer Engine Optimisation (AEO)', desc: 'Optimising for AI-generated answers.' },
  { href: '/learn/guides/ai-search-roi/', title: 'AI Search ROI – The Business Case', desc: 'The return on investment from AI search visibility.' },
  { href: '/learn/guides/check-ai-visibility/', title: 'Is My Business Visible on AI Search?', desc: 'How to check your AI visibility yourself.' },
  { href: '/learn/guides/who-should-i-hire/', title: 'Who Should I Hire for AI Search?', desc: 'How to choose the right partner.' },
  { href: '/learn/guides/google-ai-overview-optimisation/', title: 'Google AI Overview Optimisation', desc: 'How to get cited in Google AI Overviews using the Google ecosystem.' },
  { href: '/learn/guides/how-ai-chooses-businesses/', title: 'How AI Chooses Which Businesses to Recommend', desc: 'The mechanics behind AI recommendations explained.' },
  { href: '/learn/guides/appear-in-perplexity/', title: 'How to Appear in Perplexity UK', desc: 'Check and improve your Perplexity visibility.' },
  { href: '/learn/guides/ai-search-for-solicitors/', title: 'AI Search for Solicitors', desc: 'Why law firms score zero and how to fix it.' },
  { href: '/learn/guides/ai-search-b2b/', title: 'AI Search for B2B UK', desc: 'B2B AI visibility - LinkedIn, directories, case studies.' },
]
---
<Layout title="AI Search Visibility Guides | Rank4AI" description="22 in-depth guides covering AI search visibility, GEO, ChatGPT SEO, Perplexity, Copilot, entity SEO, structured data and more.">
<section class="pt-12 pb-24 reveal">
  <div class="container">
    <p class="section-tag">Guides</p>
    <h1 class="mb-4">AI Search Guides</h1>
    <p class="text-[17px] text-text-muted leading-relaxed mb-10">{guides.length} in-depth guides covering every aspect of AI search visibility.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {guides.map(guide => (
        <a href={guide.href} class="card group">
          {guide.tag && <span class="text-[10px] font-bold uppercase tracking-widest text-accent mb-2 block">{guide.tag}</span>}
          <h3 class="!text-base text-teal mb-2 group-hover:text-accent transition-colors">{guide.title}</h3>
          <p class="text-sm text-text-muted">{guide.desc}</p>
        </a>
      ))}
    </div>
  </div>
  <div class="bg-off-white border-t border-border text-center py-16 px-10 mt-16"><a href="/free-audit/" class="cta-primary">Get a Free AI Search Visibility Audit &rarr;</a></div>
</section>
</Layout>
