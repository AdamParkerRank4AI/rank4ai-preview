---
import Breadcrumbs from '../../../components/Breadcrumbs.astro'
import Layout from '../../../layouts/Layout.astro'
---
<Layout title="Free AI Search Tools | Rank4AI" description="Free AI visibility checker and llms.txt generator from Rank4AI.">
<section class="pt-12 pb-24 reveal">
  <div class="container-narrow">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Learn', href: '/learn/' },
      { label: 'Tools', href: '/learn/tools/' },
      { label: 'Tools' }
    ]} />

    <p class="section-tag">Free Tools</p>
    <h1 class="mb-6">Free Tools</h1>
    <div class="space-y-6">
      <a href="/learn/tools/ai-visibility-checker/" class="card block group"><h3 class="!text-lg text-teal mb-2 group-hover:text-accent transition-colors">AI Visibility Checker</h3><p class="text-sm text-text-muted">Quick free check of your AI search visibility across all six platforms.</p></a>
      <a href="/learn/tools/llms-txt-generator/" class="card block group"><h3 class="!text-lg text-teal mb-2 group-hover:text-accent transition-colors">Free llms.txt Generator</h3><p class="text-sm text-text-muted">Build your llms.txt file in 2 minutes. The emerging standard for communicating directly with AI systems.</p></a>
    </div>
  </div>

    <!-- Internal links -->
    <div class="mt-12 pt-8 border-t border-border">
      <h2 class="!text-xl mb-4">Related</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <a href="/learn/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">All Resources</span></a>
        <a href="/learn/guides/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">All Guides</span></a>
        <a href="/about/five-signal-framework/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">The Five Signal Model</span></a>
        <a href="/free-audit/" class="card group text-sm"><span class="font-medium text-accent">Get a Free Audit &rarr;</span></a>

      </div>
    </div>
  </div>

  <div class="bg-off-white border-t border-border text-center py-24 px-10 mt-16"><a href="/free-audit/" class="cta-primary">Get a Free AI Search Visibility Audit &rarr;</a></div>
</section>
</Layout>
