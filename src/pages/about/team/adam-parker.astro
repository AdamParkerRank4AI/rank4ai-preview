  "@type": "Person",
  "name": "Adam Parker",
  "jobTitle": "Founder",
  "worksFor": { "@type": "Organization", "name": "Rank4AI", "url": "https://www.rank4ai.co.uk" },
  "description": "Founder of Rank4AI. Creator of The Five Signal Model. Over 15 years across commercial strategy, product, technology alignment and marketing.",
  "knowsAbout": ["AI search visibility", "AI SEO", "Generative engine optimisation", "ChatGPT optimisation", "Entity-based SEO"],
  "sameAs": ["https://www.linkedin.com/in/adamparkerrank4ai/", "https://x.com/rank4ai"],
  "url": "https://www.rank4ai.co.uk/about/team/adam-parker/"
})} />

</Layout>
