---
import Breadcrumbs from '../../components/Breadcrumbs.astro'
import Layout from '../../layouts/Layout.astro'
---
<Layout title="Our Team | Rank4AI" description="Meet the Rank4AI team. No juniors. No handoffs. Senior people doing the work.">

<section class="pt-12 pb-24 reveal">
  <div class="container-narrow">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'About', href: '/about/' },
      { label: 'Team' }
    ]} />

    <p class="section-tag">Team</p>
    <h1 class="mb-6">Our Team</h1>

    <img src="/images/content/five-signal-model.svg" alt="The Five Signal Model for AI search" class="w-full rounded-xl mb-8 mt-6" loading="lazy">

    <div class="bg-off-white border-l-3 border-l-teal rounded-lg p-6 mb-8 mt-6">
      <p class="text-[15px] text-text-muted leading-relaxed">No juniors. No handoffs. No layers between you and the people doing the work. Adam Parker and Jimmy Connoley.</p>
    </div>
    <p class="text-[17px] text-text-muted leading-relaxed mb-10">No juniors. No handoffs. No layers between you and the people doing the work.</p>

    <div class="space-y-8">
      <a href="/about/team/adam-parker/" class="card group block">
        <div class="flex items-center gap-4 mb-3">
          <div class="w-12 h-12 rounded-full bg-teal text-text-light flex items-center justify-center font-bold flex-shrink-0">AP</div>
          <div>
            <h2 class="!text-xl text-teal mb-0 group-hover:text-accent">Adam Parker</h2>
            <p class="text-sm text-accent">Founder</p>
          </div>
        </div>
        <p class="text-[15px] text-text-muted leading-relaxed">AI search visibility specialist. Over 15 years in search marketing. Led AI visibility programmes for 40+ UK businesses across professional services, legal, healthcare and technology.</p>
        <span class="link text-sm mt-3 inline-block">Full profile &rarr;</span>
      </a>
      <a href="/about/team/jimmy-connoley/" class="card group block">
        <div class="flex items-center gap-4 mb-3">
          <div class="w-12 h-12 rounded-full bg-teal text-text-light flex items-center justify-center font-bold flex-shrink-0">JC</div>
          <div>
            <h2 class="!text-xl text-teal mb-0 group-hover:text-accent">Jimmy Connoley</h2>
            <p class="text-sm text-accent">Co-Founder</p>
          </div>
        </div>
        <p class="text-[15px] text-text-muted leading-relaxed">AI search strategist. Specialises in entity clarity and citation architecture for UK businesses. 12 years across B2B and professional services.</p>
        <span class="link text-sm mt-3 inline-block">Full profile &rarr;</span>
      </a>
    </div>
  </div>


    <!-- Internal links -->
    <div class="mt-12 pt-8 border-t border-border">
      <h2 class="!text-xl mb-4">Related</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <a href="/about/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">About Rank4AI</span></a>
        <a href="/about/five-signal-framework/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">Five Signal Model</span></a>
        <a href="/what-we-do/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">Our Services</span></a>
        <a href="/free-audit/" class="card group text-sm"><span class="font-medium text-accent">Get a Free Audit &rarr;</span></a>

      </div>
    </div>
  </div>

  <div class="bg-off-white border-t border-border text-center py-24 px-10 mt-16">
    <a href="/free-audit/" class="cta-primary">Get a Free AI Search Visibility Audit &rarr;</a>
  </div>
</section>

</Layout>
