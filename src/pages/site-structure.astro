---
import Layout from '../layouts/Layout.astro';
import fleet from '../data/fleet-structure.json';

interface Section { name: string; leaf_count: number; sample: string[]; more: number; }
interface Site { slug: string; name: string; abbr: string; tagline: string; tier: string; domain: string; total: number; sections: Section[]; }
const sites = fleet as Site[];

const tierColor: Record<string, string> = {
  editorial: '#0f4c81',
  leadgen: '#c2410c',
  product: '#0f766e',
};

// Group by tier label
const tiers = [
  { label: 'Editorial sites', sites: sites.filter(s => s.tier === 'editorial') },
  { label: 'Leadgen sites', sites: sites.filter(s => s.tier === 'leadgen' || s.tier === 'product') },
];

const title = 'Fleet Site Structure — Rank4AI';
const description = 'Fleet-wide site structure for the six Rank4AI fleet sites.';
---

<Layout title={title} description={description}>
  <article class="max-w-6xl mx-auto px-4 py-12">
    <nav aria-label="Breadcrumb" class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-brand">Home</a>
      <span class="mx-1">›</span>
      <span class="text-gray-700">Site structure</span>
    </nav>

    <p class="ss-eyebrow">Fleet site structure</p>
    <h1 class="ss-h1">Six sister sites at a glance</h1>
    <p class="ss-intro">All six are operated by Best Business Loans Ltd (Companies House 16833937) under common ownership. This page shows the section structure of each, with page counts. Three editorial sites (Rank4AI, Market Invoice, SEOCompare) and three leadgen sites (BestBusinessLoans, FundBiz, CardTerminals).</p>

    {tiers.map(tierGroup => (
      <section class="ss-tier">
        <h2 class="ss-tier-h">{tierGroup.label}</h2>
        <div class="ss-grid">
          {tierGroup.sites.map(site => (
            <div class="ss-col" style={`--accent: ${tierColor[site.tier]}`}>
              <div class="ss-head">
                <div class="ss-abbr">{site.abbr}</div>
                <div class="ss-meta">
                  <div class="ss-name">{site.name}</div>
                  <div class="ss-tagline">{site.tagline}</div>
                  <div class="ss-domain">{site.domain}</div>
                </div>
                <div class="ss-total">{site.total}<span>pages</span></div>
              </div>
              <div class="ss-sections">
                {site.sections.map(s => (
                  <div class="ss-section">
                    <div class="ss-shead">
                      <strong>{s.name}</strong>
                      {s.leaf_count > 0 && <span class="ss-count">{s.leaf_count}</span>}
                    </div>
                    {s.sample.length > 0 && (
                      <ul>
                        {s.sample.map(c => <li>{c}</li>)}
                        {s.more > 0 && <li class="ss-more">+{s.more} more</li>}
                      </ul>
                    )}
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}

    <p class="ss-foot">Generated from each site's sitemap-0.xml. Last refresh: 6 May 2026.</p>
  </article>
</Layout>

<style>
  .ss-eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #71717a;
    margin: 0 0 8px;
  }
  .ss-h1 {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #18181b;
    margin: 0 0 12px;
  }
  .ss-intro {
    font-size: 15px;
    color: #52525b;
    line-height: 1.55;
    max-width: 780px;
    margin: 0 0 32px;
  }
  .ss-tier {
    margin-bottom: 36px;
  }
  .ss-tier-h {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #52525b;
    margin: 0 0 16px;
    border-bottom: 1px solid #e4e4dd;
    padding-bottom: 6px;
  }
  .ss-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 768px) {
    .ss-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1100px) {
    .ss-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .ss-col {
    background: #ffffff;
    border: 1px solid #e4e4dd;
    border-top: 4px solid var(--accent);
    border-radius: 12px;
    overflow: hidden;
  }
  .ss-head {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 16px 14px;
    border-bottom: 1px solid #e4e4dd;
  }
  .ss-abbr {
    width: 40px; height: 40px;
    background: var(--accent);
    color: white;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-weight: 800;
    font-size: 13px;
    font-family: 'Source Serif 4', serif;
    flex-shrink: 0;
  }
  .ss-meta { flex: 1; min-width: 0; }
  .ss-name { font-weight: 700; font-size: 14px; font-family: 'Source Serif 4', serif; color: #18181b; }
  .ss-tagline { color: #52525b; font-size: 11px; line-height: 1.3; }
  .ss-domain { color: #71717a; font-size: 9px; text-transform: uppercase; letter-spacing: 0.04em; margin-top: 2px; }
  .ss-total {
    text-align: right;
    font-weight: 800;
    font-size: 24px;
    color: var(--accent);
    font-family: 'Source Serif 4', serif;
    line-height: 1;
  }
  .ss-total span {
    display: block;
    font-size: 8px;
    font-weight: 600;
    color: #71717a;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 2px;
    font-family: 'Inter', sans-serif;
  }
  .ss-sections {
    padding: 12px 16px 16px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 14px;
  }
  .ss-section { font-size: 11px; }
  .ss-shead {
    font-size: 11px;
    margin-bottom: 4px;
    border-bottom: 1px dashed #e4e4dd;
    padding-bottom: 3px;
    color: #18181b;
  }
  .ss-shead strong { font-weight: 700; text-transform: lowercase; }
  .ss-count {
    background: var(--accent);
    color: white;
    font-weight: 700;
    padding: 1px 5px;
    border-radius: 999px;
    font-size: 9px;
    margin-left: 4px;
  }
  .ss-section ul { margin: 0; padding: 0; list-style: none; }
  .ss-section li {
    color: #52525b;
    font-size: 10px;
    padding: 1px 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ss-section li.ss-more { color: #71717a; font-style: italic; }
  .ss-foot { color: #71717a; font-size: 11px; text-align: center; margin: 24px 0 0; }
</style>
