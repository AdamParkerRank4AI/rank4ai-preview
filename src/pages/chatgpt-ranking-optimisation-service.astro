      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <a href="/what-we-do/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">Our Services</span></a>
        <a href="/about/five-signal-framework/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">Five Signal Model</span></a>
        <a href="/learn/guides/complete-guide-ai-search/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">Complete Guide</span></a>
        <a href="/free-audit/" class="card group text-sm"><span class="font-medium text-accent">Free Audit &rarr;</span></a>
