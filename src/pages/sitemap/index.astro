---
import Breadcrumbs from '../../components/Breadcrumbs.astro'
import Layout from '../../layouts/Layout.astro'
---
<Layout title="AI Knowledge Map | Rank4AI" description="Complete map of all AI search visibility content on Rank4AI.">
<section class="pt-12 pb-24">
  <div class="container">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Sitemap' }
    ]} />

    <h1 class="mb-6">AI Knowledge Map</h1>
    <p class="text-[17px] text-text-muted leading-relaxed mb-10">A complete map of everything we cover.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 text-sm">
      <div>
        <h2 class="!text-lg mb-3">What We Do</h2>
        <ul class="space-y-1.5 text-text-muted">
          <li><a href="/what-we-do/" class="hover:text-accent">Services Overview</a></li>
          <li><a href="/what-we-do/ai-visibility-audit/" class="hover:text-accent">AI Visibility Audit</a></li>
          <li><a href="/what-we-do/ecosystem-services/" class="hover:text-accent">Ecosystem Services</a></li>
          <li><a href="/what-we-do/full-agency/" class="hover:text-accent">Full Agency</a></li>
          <li><a href="/what-we-do/pricing/" class="hover:text-accent">Pricing</a></li>
        </ul>
      </div>
      <div>
        <h2 class="!text-lg mb-3">Research</h2>
        <ul class="space-y-1.5 text-text-muted">
          <li><a href="/research/" class="hover:text-accent">Research Hub</a></li>
          <li><a href="/research/uk-ai-visibility-stats/" class="hover:text-accent">UK AI Visibility Statistics</a></li>
          <li><a href="/research/case-studies/" class="hover:text-accent">Case Studies</a></li>
          <li><a href="/research/weekly-intelligence/" class="hover:text-accent">Weekly Intelligence</a></li>
          <li><a href="/research/methodology/" class="hover:text-accent">Methodology</a></li>
          <li><a href="/research/rankings/" class="hover:text-accent">Rankings</a></li>
        </ul>
      </div>
      <div>
        <h2 class="!text-lg mb-3">Learn</h2>
        <ul class="space-y-1.5 text-text-muted">
          <li><a href="/learn/guides/" class="hover:text-accent">Guides (20)</a></li>
          <li><a href="/learn/glossary/" class="hover:text-accent">Glossary</a></li>
          <li><a href="/learn/tools/" class="hover:text-accent">Free Tools</a></li>
          <li><a href="/learn/questions/" class="hover:text-accent">Questions (285)</a></li>
        </ul>
      </div>
      <div>
        <h2 class="!text-lg mb-3">About</h2>
        <ul class="space-y-1.5 text-text-muted">
          <li><a href="/about/" class="hover:text-accent">About Rank4AI</a></li>
          <li><a href="/about/how-we-work/" class="hover:text-accent">How We Work</a></li>
          <li><a href="/about/five-signal-framework/" class="hover:text-accent">Five Signal Model</a></li>
          <li><a href="/about/our-story/" class="hover:text-accent">Our Story</a></li>
          <li><a href="/about/team/" class="hover:text-accent">Team</a></li>
        </ul>
      </div>
      <div>
        <h2 class="!text-lg mb-3">Blog &amp; Podcast</h2>
        <ul class="space-y-1.5 text-text-muted">
          <li><a href="/blog/" class="hover:text-accent">Blog (104 posts)</a></li>
          <li><a href="/podcast/" class="hover:text-accent">Podcast</a></li>
        </ul>
      </div>
      <div>
        <h2 class="!text-lg mb-3">Get Started</h2>
        <ul class="space-y-1.5 text-text-muted">
          <li><a href="/free-audit/" class="hover:text-accent">Free AI Search Visibility Audit</a></li>
          <li><a href="/book-a-call/" class="hover:text-accent">Book a Call</a></li>
          <li><a href="/contact/" class="hover:text-accent">Contact</a></li>
        </ul>
      </div>
    </div>
  </div>
</section>
</Layout>
