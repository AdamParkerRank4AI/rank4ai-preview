import Layout from '../../layouts/Layout.astro'
---
<Layout title="Responsible AI | Rank4AI" description="Rank4AI's approach to responsible AI practices. How we work ethically with AI search systems.">
<section class="pt-12 pb-24">
  <div class="container-narrow">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Responsible Ai' }
    ]} />

    <h1 class="mb-6">Responsible AI</h1>

    <img src="/images/content/ai-search-signals.svg" alt="AI search visibility signals" class="w-full rounded-xl mb-8 mt-6" loading="lazy">
    <div class="prose max-w-none text-[15px] text-text-muted leading-relaxed">
      <p>Rank4AI is committed to working responsibly with AI search systems. Our approach is built on transparency, honesty, and ethical practice.</p>
      <h2>Our Principles</h2>
      <p><strong>We observe, we do not manipulate.</strong> Our audit methodology observes how AI platforms currently interpret a business. We do not attempt to game, trick, or exploit AI systems.</p>
      <p><strong>We are transparent about limitations.</strong> Inclusion in AI answers cannot be guaranteed. AI systems evolve, weightings shift, and retrieval varies by context. We engineer stability – we do not control platforms.</p>
      <p><strong>We build genuine signals.</strong> The signals we strengthen – identity clarity, subject authority, ecosystem validation – are genuine representations of what a business is. We do not create false signals or misleading content.</p>
      <p><strong>We respect data.</strong> We operate under UK GDPR principles and the Data Protection Act 2018. We do not access private systems or data without explicit permission.</p>
      <p><strong>We are honest about what we know and what we do not.</strong> AI search is a rapidly evolving field. We share our research openly and acknowledge uncertainty where it exists.</p>
    </div>
  </div>

  <div class="bg-off-white border-t border-border text-center py-16 px-10 mt-16">
    <a href="/free-audit/" class="cta-primary">Get a Free AI Search Visibility Audit &rarr;</a>
  </div>
</section>
</Layout>
