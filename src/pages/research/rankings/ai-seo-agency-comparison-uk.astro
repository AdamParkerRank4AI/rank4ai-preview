          </tr>
          <tr class="border-b border-border">
            <td class="px-4 py-3 font-semibold">Found</td>
            <td class="px-4 py-3">AI-first Everysearch</td>
            <td class="px-4 py-3">Luminr technology</td>
            <td class="px-4 py-3">Multi-platform</td>
