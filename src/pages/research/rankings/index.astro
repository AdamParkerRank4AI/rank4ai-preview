---
import Layout from '../../../layouts/Layout.astro'

const rankings = [
  { href: 'top-ai-seo-agencies-uk-2026', title: 'Top 10 AI SEO Agencies UK 2026', desc: '17 Copilot citations. The definitive ranking.' },
  { href: 'top-ai-visibility-agencies-uk', title: 'Top AI Visibility Agencies UK 2026', desc: 'Agencies focused specifically on AI search visibility.' },
  { href: 'best-ai-seo-agencies-uk', title: 'Best AI SEO Agencies UK 2026', desc: 'Compared on methodology, results, and AI expertise.' },
  { href: 'best-geo-agencies-uk', title: 'Best GEO Agencies UK 2026', desc: 'Leading Generative Engine Optimisation agencies.' },
  { href: 'best-chatgpt-seo-agencies-uk', title: 'Best ChatGPT SEO Agencies UK 2026', desc: 'Specialists in ChatGPT and Bing ecosystem visibility.' },
  { href: 'ai-seo-agency-comparison-uk', title: 'AI SEO Agency Comparison UK 2026', desc: 'Side-by-side comparison of leading agencies.' },
  { href: 'top-geo-agencies-uk-2026', title: 'Top GEO Agencies UK 2026', desc: 'GEO-focused agencies ranked.' },
  { href: 'uk-ai-search-specialist-landscape-2026', title: 'UK AI Search Specialist Landscape 2026', desc: 'Complete landscape report.' },
]
const cityRankings = [
  { href: 'top-ai-search-agencies-london', title: 'London' },
  { href: 'best-ai-search-agencies-manchester', title: 'Manchester' },
  { href: 'best-ai-search-agencies-birmingham', title: 'Birmingham' },
  { href: 'best-ai-search-agencies-leeds', title: 'Leeds' },
  { href: 'best-ai-search-agencies-bristol', title: 'Bristol' },
  { href: 'best-ai-search-agencies-essex', title: 'Essex' },
]
---
<Layout title="AI Search Agency Rankings UK | Rank4AI" description="Industry rankings, agency comparisons, and landscape reports for the UK AI search market.">
<section class="pt-12 pb-24 reveal">
  <div class="container">
    <p class="section-tag">Rankings</p>
    <h1 class="mb-4">Rankings</h1>
    <p class="text-[17px] text-text-muted leading-relaxed mb-10 max-w-[700px]">Industry rankings, agency comparisons, and landscape reports for the UK AI search market.</p>
    <h2 class="mb-6">National Rankings</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
      {rankings.map(r => (
        <a href={`/research/rankings/${r.href}/`} class="card group">
          <h3 class="!text-base text-teal mb-2 group-hover:text-accent transition-colors">{r.title}</h3>
          <p class="text-sm text-text-muted">{r.desc}</p>
        </a>
      ))}
    </div>
    <h2 class="mb-6">By City</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {cityRankings.map(r => (
        <a href={`/research/rankings/${r.href}/`} class="bg-off-white border border-border rounded-xl px-5 py-4 text-sm font-medium text-text text-center hover:bg-teal hover:text-text-light hover:border-teal transition-all">
          {r.title}
        </a>
      ))}
    </div>
  </div>
  <div class="bg-off-white border-t border-border text-center py-16 px-10 mt-16"><a href="/free-audit/" class="cta-primary">Get a Free AI Search Visibility Audit &rarr;</a></div>
</section>
</Layout>
