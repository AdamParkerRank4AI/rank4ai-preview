---
import Layout from '../../../layouts/Layout.astro'
import Breadcrumbs from '../../../components/Breadcrumbs.astro'
import weekly from '../../../data/weekly.json'

export function getStaticPaths() {
  return weekly.map((w: any) => ({
    params: { slug: w.slug },
    props: w
  }))
}

const { title, slug, topSummary, bodyContent, cardExcerpt, metaTitle, metaDesc, author, publishDate } = Astro.props
const pageTitle = metaTitle || `${title} | Rank4AI`
const pageDesc = metaDesc || cardExcerpt || topSummary || ''
const pubDate = publishDate ? new Date(publishDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) : ''
---
<Layout title={pageTitle} description={pageDesc}>
<article class="pt-12 pb-24">
  <div class="container-narrow">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Research', href: '/research/' },
      { label: 'Weekly Intelligence', href: '/research/weekly-intelligence/' },
      { label: title }
    ]} />
    <p class="text-[11px] font-semibold uppercase tracking-widest text-accent mb-4">Weekly Intelligence</p>
    <h1 class="!text-3xl mb-4">{title}</h1>
    <div class="flex gap-4 text-sm text-text-muted mb-8">
      {author && <span>By {author}</span>}
      {pubDate && <span>{pubDate}</span>}
    </div>
    {topSummary && (
      <div class="bg-off-white border-l-3 border-l-teal rounded-lg p-6 mb-8">
        <p class="text-[15px] text-text-muted leading-relaxed">{topSummary}</p>
      </div>
    )}
    {bodyContent ? (
      <div class="prose max-w-none text-[17px] text-text-muted leading-relaxed" set:html={bodyContent} />
    ) : (
      <p class="text-[17px] text-text-muted">{cardExcerpt}</p>
    )}
  </div>
  <div class="bg-off-white border-t border-border text-center py-16 px-10 mt-16"><a href="/free-audit/" class="cta-primary">Get a Free AI Search Visibility Audit &rarr;</a></div>
</article>
</Layout>
