---
import Breadcrumbs from '../../../components/Breadcrumbs.astro'
import Layout from '../../../layouts/Layout.astro'
---
<Layout title="AI Search Visibility Case Studies | Rank4AI" description="Real AI search visibility results for real businesses. Case studies from Rank4AI.">
<section class="pt-12 pb-24 reveal">
  <div class="container-narrow">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Research', href: '/research/' },
      { label: 'Case Studies', href: '/research/case-studies/' },
      { label: 'Case Studies' }
    ]} />

    <p class="section-tag">Case Studies</p>
    <h1 class="mb-6">Case Studies</h1>

    <img src="/images/content/stat-77-percent.svg" alt="UK AI visibility research data" class="w-full rounded-xl mb-8 mt-6" loading="lazy">
    <p class="text-[17px] text-text-muted leading-relaxed mb-10">Real results for real businesses. How AI search visibility was measured, built, and improved.</p>
    <div class="card mb-6">
      <h3 class="!text-lg text-teal mb-2">AI Visibility Case Study</h3>
      <p class="text-sm text-text-muted leading-relaxed mb-3">A UK professional services business working with Rank4AI to build AI search visibility from the ground up. Audit findings, strategy, and outcomes across all six AI platforms.</p>
      <a href="/research/case-studies/ai-visibility/" class="link text-sm">Read case study &rarr;</a>
    </div>
    <p class="text-sm text-text-muted italic">More case studies being published. Check back soon.</p>
  </div>

    <!-- Internal links -->
    <div class="mt-12 pt-8 border-t border-border">
      <h2 class="!text-xl mb-4">Related</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <a href="/research/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">All Research</span></a>
        <a href="/research/uk-ai-visibility-stats/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">UK AI Statistics</span></a>
        <a href="/research/methodology/" class="card group text-sm"><span class="font-medium text-teal group-hover:text-accent">Our Methodology</span></a>
        <a href="/free-audit/" class="card group text-sm"><span class="font-medium text-accent">Get a Free Audit &rarr;</span></a>

      </div>
    </div>
  </div>

  <div class="bg-off-white border-t border-border text-center py-24 px-10 mt-16">
    <a href="/free-audit/" class="cta-primary">Get a Free AI Search Visibility Audit &rarr;</a>
  </div>
</section>
</Layout>
