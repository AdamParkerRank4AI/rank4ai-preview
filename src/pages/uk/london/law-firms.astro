    <AuthorBox name="Oliver Mackman" initials="OM" role="Operations and Marketing Director, Rank4AI" bio="Oliver leads operations and marketing at Rank4AI. He works on technical AI search optimisation and analytics for client engagements." dateModified="2026-05-09" />
  </div>

