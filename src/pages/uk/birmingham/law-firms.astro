  url="https://www.rank4ai.co.uk/uk/birmingham/law-firms/"
  dateModified="2026-05-09"
  author="Jimmy Connoley"
/>

<section class="pt-12 pb-24 reveal">
  <div class="container-narrow">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'UK', href: '/uk/' },
      { label: 'Birmingham', href: '/who-we-help/birmingham/' },
