---
/**
 * Floating CTA - appears after scrolling past the hero section.
 * Sticks to bottom of screen on mobile, bottom-right on desktop.
 * Disappears when user scrolls back to top.
 */
---

<div id="floating-cta" class="fixed bottom-4 right-4 z-40 hidden">
  <!-- Desktop: compact button -->
  <a href="/free-audit/"
    class="hidden sm:inline-flex items-center gap-2 px-5 py-3 bg-[#2bb891] hover:bg-[#239e7b] text-white text-sm font-bold rounded-xl shadow-lg shadow-[#2bb891]/25 transition-all hover:scale-105">
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
    Get a Free AI Search Visibility Audit
  </a>

  <!-- Mobile: full-width bar with dismiss -->
  <div id="floating-cta-mobile" class="sm:hidden fixed bottom-0 left-0 right-0 bg-[#eeece2] border-t border-[#0f2d2c]/10 px-3 py-2.5 shadow-lg flex items-center gap-2">
    <a href="/free-audit/"
      class="flex-1 inline-flex items-center justify-center gap-1.5 py-2.5 bg-[#2bb891] hover:bg-[#239e7b] text-white text-sm font-bold rounded-xl transition-colors">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      Free AI Audit
    </a>
    <button id="floating-cta-close" type="button" aria-label="Dismiss"
      class="shrink-0 w-9 h-9 flex items-center justify-center text-[#0f2d2c]/60 hover:text-[#0f2d2c] hover:bg-[#0f2d2c]/5 rounded-lg transition-colors">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
  </div>
</div>

<script>
  const floatingCTA = document.getElementById('floating-cta');
  const closeBtn = document.getElementById('floating-cta-close');
  // Persist dismiss for the session (sessionStorage clears on tab close)
  let dismissed = sessionStorage.getItem('r4-floating-cta-dismissed') === '1';
  if (closeBtn) {
    closeBtn.addEventListener('click', () => {
      dismissed = true;
      sessionStorage.setItem('r4-floating-cta-dismissed', '1');
      if (floatingCTA) floatingCTA.classList.add('hidden');
    });
  }
  if (floatingCTA) {
    window.addEventListener('scroll', () => {
      if (dismissed) return;
      const scrollY = window.scrollY;
      if (scrollY > 400) {
        floatingCTA.classList.remove('hidden');
      } else {
        floatingCTA.classList.add('hidden');
      }
    }, { passive: true });
  }
</script>
