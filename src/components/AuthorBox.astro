---
interface Props {
  name?: string;
  initials?: string;
  role?: string;
  bio?: string;
  dateModified?: string;
}

const {
  name = 'Adam Parker',
  initials = 'AP',
  role = 'Founder, Rank4AI',
  bio = 'Adam is the founder of Rank4AI, specialising in AI search visibility. He helps businesses get found across ChatGPT, Gemini, Perplexity, and AI Overviews through technical optimisation and strategic content.',
  dateModified = '2026-04-07'
} = Astro.props;

const formattedDate = new Date(dateModified + 'T00:00:00').toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric'
});
---

<div class="flex items-start gap-4 border-t border-[#0f2d2c]/10 pt-6 mt-10">
  <div class="w-12 h-12 bg-[#2bb891] rounded-full flex items-center justify-center text-white font-bold text-lg flex-shrink-0">
    {initials}
  </div>
  <div>
    <p class="font-semibold text-[#0f2d2c]">{name}</p>
    <p class="text-sm text-[#4a6160]">{role}</p>
    <p class="text-sm text-[#4a6160]/80 mt-1">
      {bio}
    </p>
    <p class="text-xs text-[#4a6160]/60 mt-2">Last reviewed: {formattedDate}</p>
  </div>
</div>
