---
/**
 * Speakable Schema Component
 *
 * Adds Article schema with SpeakableSpecification + linked @id references.
 * <10% of websites use Speakable. 127% increase in AI search referrals.
 * Connected to site-wide @graph via @id references — author resolves to
 * the full Person node in src/data/authors.ts via Layout.astro.
 */

import { authorByName } from '../data/authors';

interface Props {
  title: string;
  description: string;
  datePublished?: string;
  dateModified?: string;
  url?: string;
  author?: string;
}

const { title, description, datePublished, dateModified, url, author } = Astro.props;
const siteUrl = 'https://www.rank4ai.co.uk';
const pageUrl = url || new URL(Astro.url.pathname, siteUrl).href;
const resolvedAuthor = authorByName(author);

// ISO 8601 with TZ — Bing/AI engines prioritise pages with full datetime.
// Date-only inputs are coerced to start-of-day UTC. Per 11 May 2026 audit.
const buildDate = new Date().toISOString();
const toIso = (d?: string): string => !d ? buildDate : (/^\d{4}-\d{2}-\d{2}$/.test(d) ? `${d}T00:00:00.000Z` : d);
const resolvedPublished = toIso(datePublished);
const resolvedModified = toIso(dateModified || datePublished);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": pageUrl + "#article",
  "headline": title,
  "description": description,
  "datePublished": resolvedPublished,
  "dateModified": resolvedModified,
  "url": pageUrl,
  "isPartOf": { "@id": siteUrl + "/#website" },
  "author": { "@id": resolvedAuthor.ref },
  "publisher": { "@id": siteUrl + "/#localbusiness" },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": [".answer-capsule", ".key-takeaway"]
  }
};
---

<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
